<?xml version="1.0" encoding="utf-8" ?>
<component name="home_screen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/home_screen/home_screen.brs" />
  <script type="text/brightscript" uri="pkg:/components/helpers/VodEntityHelper.brs" />
  <script type="text/brightscript" uri="pkg:/source/StaticContent.brs" />
  <script type="text/brightscript" uri="pkg:/components/helpers/ChannelEntityHelper.brs" />
  <interface>
    <field id="homeScreenDataEntity" type="array" onChange="updateHomeScreen"/>
    <field id="liveChannelsEntity" type="array" onChange="fetchLiveScreenData"/>
    <field id="lastFocusedChild" type="integer" />
  </interface>
  <children>
    <Group id="mainGroup" visible="true">
      <Group id="contentContainer" translation="[160, 20]">
        <Poster
        uri="pkg:/images/png/gradient.jpeg"
        width="1920"
        height="1080"
        loadDisplayMode="scaleToFill"
        translation="[-20, -20]"/>

        <RowList 
          id = "exampleRowList" 
          translation = "[ 0, 0 ]" 
          itemComponentName = "RowListItemComponent" 
          
          
          itemSpacing = "[ 0, 0 ]" 
          rowItemSpacing = "[ [15,20] ]"
          rowLabelOffset="[[0, 15]]"
          showRowLabel = "[ true ]"
          rowHasFocus = "false"
          numRows="4"
          rowFocusAnimationStyle="fixedFocus"
          />
      </Group>

      <!-- rowItemSize = "[ [300, 420] ]"   -->
      <!-- itemSize = "[ 1920, 520 ]"  -->
    </Group>
  </children>
</component>