<?xml version="1.0" encoding="utf-8" ?>
<component name="dynamic_navigation_bar" extends="Group" z="10">
  <script type="text/brightscript" uri="pkg:/components/screens/dynamic_navigation_bar.brs" />
  <interface>
    <field id="navHasFocus" type="bool" onChange="focusUpdated"/>
    <field id="navigationData" type="array" onChange="buildNavigationItems"/>
    <field id="selectedIndex" type="int" value="0" onChange="onSelectedIndexChanged"/>
    <field id="isCollapsed" type="bool" value="false"/>
    <function name="reloadNavigation" />
    <function name="buildNavigationItems" />
    <function name="collapseNav" />
    <function name="expandNav" />
  </interface>
  <children>
    <!-- Animation for collapsing/expanding navigation -->
    <Animation id="collapseAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="collapseInterpolator" key="[0.0, 1.0]" keyValue="[[0, 0], [-240, 0]]" fieldToInterp="dynamic_navigation_bar.translation"/>
    </Animation>
    
    <Animation id="expandAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="expandInterpolator" key="[0.0, 1.0]" keyValue="[[-240, 0], [0, 0]]" fieldToInterp="dynamic_navigation_bar.translation"/>
    </Animation>

    <Rectangle
      id="navBarBackground"
      width="240"
      height="1080"
      color="#1e2328" />

    <!-- Logo at the top - centered in 240px nav bar -->
    <Group id="logoGroup" translation="[60, 15]">
      <Poster
        id="logoImage"
        uri="pkg:/images/img/gia-tv-small.png"
        width="120"
        height="120"
        loadDisplayMode="scaleToFill" />
    </Group>

    <!-- Search tab removed - using only dynamic navigation -->

    <!-- Dynamic navigation items will be added here -->
    <Group id="dynamicNavContainer" translation="[0, 0]" />

    <!-- Account - Always at bottom (text only) -->
  
  </children>
</component>
