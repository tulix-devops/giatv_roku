<?xml version="1.0" encoding="UTF-8"?>
<component name="NavItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet" />
        <field id="focused" type="boolean" value="false" onChange="onFocusChanged" />
        <field id="selected" type="boolean" value="false" onChange="onSelectedChanged" />
    </interface>
    <script type="text/brightscript" uri="NavItem.brs" />
    <children>
        <Group>
            <!-- Focus background (bright, animated when navigating) -->
            <Rectangle
                id="focusBackground"
                width="170"
                height="70"
                color="#ffffff"
                opacity="0.9"
                translation="[5, 10]"
                visible="false"
            />
            
            <!-- Focus border (bright outline when navigating) -->
            <Rectangle
                id="focusBorder"
                width="174"
                height="74"
                color="#f16667"
                opacity="1.0"
                translation="[3, 8]"
                visible="false"
            />
            
            <!-- Selected background (subtle, persistent for active tab) -->
            <Rectangle
                id="selectedBackground"
                width="170"
                height="70"
                color="#f16667"
                opacity="0.3"
                translation="[5, 10]"
                visible="false"
            />
            
            <!-- Selected indicator (left border for active tab) -->
            <Rectangle
                id="selectedIndicator"
                width="4"
                height="70"
                color="#f16667"
                opacity="1.0"
                translation="[0, 10]"
                visible="false"
            />
            
            <!-- Main background (default state) -->
            <Rectangle
                id="background"
                width="170"
                height="70"
                color="#1a1a2e"
                opacity="0.6"
                translation="[5, 10]"
            />
            
            <!-- Title (centered) -->
            <Label
                id="title"
                text="Nav Item"
                color="#ffffff"
                horizAlign="center"
                vertAlign="center"
                translation="[0, 10]"
                width="180"
                height="70"
            >
                <Font uri="pkg:/images/UrbanistMedium.ttf" size="22" />
            </Label>
        </Group>
    </children>
</component>