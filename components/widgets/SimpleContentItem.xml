<?xml version="1.0" encoding="utf-8" ?>
<component name="SimpleContentItem" extends="Group">
  <script type="text/brightscript" uri="SimpleContentItem.brs" />
  <interface>
    <field id="itemContent" type="node" onChange="onContentSet"/>
  </interface>
  <children>
    <!-- Content poster -->
    <Poster
      id="contentPoster"
      width="300"
      height="420"
      loadDisplayMode="scaleToFit"
      failedBitmapUri="pkg:/images/png/poster_not_found_220x375.png"
      translation="[0, 0]" />
    
    <!-- Title overlay -->
    <Rectangle
      id="titleBackground"
      width="300"
      height="60"
      color="#000000CC"
      translation="[0, 360]" />
    
    <Label
      id="contentTitle"
      text=""
      color="#ffffff"
      font="font:UrbanistMedium"
      translation="[10, 370]"
      width="280"
      height="40"
      horizAlign="left"
      vertAlign="center"
      wrap="true">
      <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
    </Label>
    
    <!-- Focus indicator -->
    <Rectangle
      id="focusIndicator"
      width="300"
      height="420"
      color="#f16667"
      cornerRadius="8"
      opacity="0"
      translation="[0, 0]" />
  </children>
</component>
