<?xml version="1.0" encoding="UTF-8"?>
<component name="SimpleNavigationItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet" />
    </interface>
    <script type="text/brightscript" uri="SimpleNavigationItem.brs" />
    <children>
        <Group>
            <!-- Simple background -->
            <Rectangle
                id="background"
                width="180"
                height="70"
                color="#2a2a3e"
                opacity="0.8"
                translation="[0, 0]"
            />
            
            <!-- Focus indicator -->
            <Rectangle
                id="focusIndicator"
                width="180"
                height="70"
                color="#f16667"
                opacity="0.3"
                translation="[0, 0]"
                visible="false"
            />
            
            <!-- Title -->
            <Label
                id="title"
                text="Navigation Item"
                color="#ffffff"
                font="font:UrbanistMedium"
                horizAlign="center"
                vertAlign="center"
                translation="[0, 0]"
                width="180"
                height="70"
            >
                <Font uri="pkg:/images/UrbanistMedium.ttf" size="22" />
            </Label>
        </Group>
    </children>
</component>