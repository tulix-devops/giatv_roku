<?xml version="1.0" encoding="utf-8" ?>

<component name="DVRItem" extends="Group">

  <interface>

    <function name="hasFocus"  />

    <field id="width" type="float" onChange="updateLayout"/>
    <field id="height" type="float" onChange="updateLayout"/>
    <field id="itemContent" type="node" onChange="itemContentChanged" />
    <field id="focusPercent" type="float" onChange="itemFocusChanged" />
    <field id="rowFocusPercent" type="float" onChange="itemFocusChanged" />
  </interface>

  <script type="text/brightscript" uri="pkg:/components/widgets/DVRItem.brs" />

  <children>

    <Rectangle id="posterBackground" color="0x00000088" />

    <Poster id="poster" />

    <Group id="detailGroup" visible="true" >

      <Rectangle
        id="backgroundRectangle" />

      <MaskGroup
        id="detailMaskGroup"
        maskUri="pkg:/images/custom-item-mask-rev.png">

        <Rectangle
          id="contentRectangle"
          color="0x00000000"
          opacity="0.0" 
          translation ="[0,50]"/>

      </MaskGroup>

      <!--
      <Rectangle
        id="backgroundTopBorderRectangle"
        color="0x000000"
        height="2" /> -->

      <!--This the shadow of the first text-->
      <Label
        translation="[0, 38]"
        id="titleShadowLabel"
        color="0x000000"
        font="font:MediumBoldSystemFont"
        horizAlign="center"
        vertAlign="top" />

      <!--This the the first text-->
      <Label
        translation="[0, 38]"
        id="titleLabel"
        color="0xFFFFFF"
        font="font:MediumBoldSystemFont"
        horizAlign="center"
        vertAlign="top" />
        
      <Label
        translation="[0, 0]"
        id="descriptionShadowLabel"
        color="0x000000"
        font="font:MediumBoldSystemFont"
        horizAlign="center"
        vertAlign="bottom" />

      <Label
        translation="[0, 0]"
        id="descriptionLabel"
        color="0x777777"
        font="font:MediumBoldSystemFont"
        horizAlign="center"
        vertAlign="bottom" />
        

    </Group>
    <!--
    <Animation
      id="detailGroupAnimation"
      duration="0.8"
      easeFunction="linear" >

      <FloatFieldInterpolator
        id = "detailGroupOpacity"
        key="[0.0, 0.6, 1.0]"
        keyValue="[ 0.0, 0.0, 0.75]"
        fieldToInterp="detailGroup.opacity" />

    </Animation>
-->
  </children>

</component>
