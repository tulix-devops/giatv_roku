<?xml version="1.0" encoding="utf-8" ?>
<component name="M3UChannelItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged"/>
        <field id="focusPercent" type="float" onChange="onFocusPercentChanged"/>
        <field id="width" type="float" value="370"/>
        <field id="height" type="float" value="268"/>
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/M3UChannelItem.brs"/>

    <children>
        <!-- Card background -->
        <Rectangle
            id="background"
            width="370"
            height="268"
            color="#131720"/>

        <!-- Focus border — white outline, shown when focused -->
        <Rectangle
            id="focusBorder"
            translation="[-2, -2]"
            width="374"
            height="272"
            color="#ffffff"
            opacity="0.0"/>

        <!-- Inner card background (on top of focus border) -->
        <Rectangle
            id="innerBackground"
            width="370"
            height="268"
            color="#131720"/>

        <!-- Poster area -->
        <Poster
            id="channelPoster"
            translation="[0, 0]"
            width="370"
            height="210"
            loadDisplayMode="scaleToZoom"
            loadingBitmapUri="pkg:/images/png/poster_not_found_350x245.png"
            failedBitmapUri="pkg:/images/png/poster_not_found_350x245.png"/>

        <!-- Bottom title section background -->
        <Rectangle
            id="titleBg"
            translation="[0, 210]"
            width="370"
            height="58"
            color="#0f1623"/>

        <!-- Channel name -->
        <Label
            id="bottomTitle"
            translation="[10, 214]"
            text="Channel Name"
            color="#cccccc"
            width="350"
            height="30"
            maxLines="1"
            ellipsisText="...">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="22"/>
        </Label>

        <!-- Category label -->
        <Label
            id="categoryLabel"
            translation="[10, 244]"
            text=""
            color="#9ca3af"
            width="350"
            height="22">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18"/>
        </Label>
    </children>
</component>
