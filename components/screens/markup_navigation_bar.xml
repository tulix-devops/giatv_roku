<?xml version="1.0" encoding="utf-8" ?>
<component name="markup_navigation_bar" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/markup_navigation_bar.brs" />
  <interface>
    <field id="navHasFocus" type="bool" onChange="onFocusUpdated"/>
    <field id="navigationData" type="array" onChange="buildNavigationItems"/>
    <field id="selectedIndex" type="int" value="0" onChange="onSelectedIndexChanged"/>
  </interface>
  <children>
    <Rectangle
      id="navBarBackground"
      width="200"
      height="1080"
      color="#1a1a2e" />

    <!-- Logo at the top -->
    <Group id="logoGroup" translation="[40, 15]">
      <Poster
        id="logoImage"
        uri="pkg:/images/png/gia-tv-logo.png"
        width="120"
        height="120"
        loadDisplayMode="scaleToFit" />
    </Group>

    <!-- Navigation Group -->
    <Group id="navGroup" translation="[10, 150]">
      <MarkupList
        id="navList"
        itemComponentName="NavItem"
        itemSize="[180, 90]"
        numRows="6"
        itemSpacing="[0, 10]"
        vertFocusAnimationStyle="floatingFocus"
        drawFocusFeedback="false"
        translation="[10, 150]"
        width="180"
        height="700"
      />
    </Group>

    <!-- Account - Always at bottom -->
    <Group id="accountGroup" translation="[15, 900]" focusable="true" width="170" height="55">
      <Rectangle
        id="accountFocusIndicator"
        width="170"
        height="60"
        color="#f16667"
        opacity="0.2"
        translation="[0, -2]"
        visible="false" />
      <Label text="Account" color="#ffffff" font="font:UrbanistMedium" translation="[15, 20]" width="170" horizAlign="center">
        <Font uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
  </children>
</component>