<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesItemComponent" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet"/>
        <field id="focusPercent" type="float" onChange="showFocus"/>
        <field id="width" type="float" value="350"/>
        <field id="height" type="float" value="245"/>
    </interface>

    <script type="text/brightscript" uri="pkg:/components/widgets/SeriesItemComponent.brs"/>

    <children>
        <!-- Main Container -->
        <Group id="itemContainer" translation="[0, 0]">
            
            <!-- Poster Image (16:9 landscape) -->
            <Poster
                id="posterImage"
                width="350"
                height="197"
                translation="[0, 0]"
                loadDisplayMode="scaleToZoom"
                loadingBitmapUri="pkg:/images/png/poster_not_found_350x245.png"
                failedBitmapUri="pkg:/images/png/poster_not_found_350x245.png"/>
            
            <!-- Live Badge (top-left corner of image) -->
            <Poster
                id="liveBadge"
                uri="pkg:/images/png/live_50x30_small_text.png"
                width="50"
                height="30"
                translation="[10, 10]"
                visible="false"
                loadDisplayMode="noScale"/>
            
            <!-- Title Label -->
            <Label
                id="titleLabel"
                text=""
                width="350"
                height="40"
                translation="[0, 203]"
                horizAlign="left"
                vertAlign="top"
                color="0xCCCCCCFF"
                font="font:TinyBoldSystemFont"
                maxLines="2"
                ellipsisText="..."/>
        </Group>
    </children>
</component>