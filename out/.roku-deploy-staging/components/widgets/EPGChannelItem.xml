<?xml version="1.0" encoding="utf-8" ?>
<!-- Simplified EPG Channel Item (based on SGDEX TimeGridChannelItemComponent pattern) -->
<component name="EPGChannelItem" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentSet" />
        <field id="width" type="float" onChange="onLayoutChanged" />
        <field id="height" type="float" onChange="onLayoutChanged" />
    </interface>
    
    <script type="text/brightscript" uri="pkg:/components/widgets/EPGChannelItem.brs" />
    
    <children>
        <!-- Channel logo/poster: TimeGrid manages background color -->
        <Poster id="poster" 
                loadDisplayMode="scaleToFit"
                loadingBitmapUri=""
                failedBitmapUri="" />
        
        <!-- Channel title: Hidden fallback (logo-only display as requested) -->
        <Label id="title" 
               font="font:MediumSystemFont"
               color="#FFFFFF"
               horizAlign="center"
               vertAlign="center"
               visible="false" />
    </children>
</component>
