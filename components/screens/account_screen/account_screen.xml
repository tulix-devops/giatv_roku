<?xml version="1.0" encoding="utf-8" ?>
<component name="account_screen" extends="Group" focusable="true">
    <script type="text/brightscript" uri="pkg:/components/screens/account_screen/account_screen.brs" />
    <interface>
        <field id="accountStatus" type="boolean"/>
        <field id="userData" type="assocarray" onChange="onUserDataChanged"/>
        <function name="refreshUserData" />
    </interface>
    <children>
        <!-- Modern dark background - adjusted for 240px nav bar -->
        <Rectangle
            id="modernBackground"
            width="1600"
            height="1080"
            color="#0f1419"
            translation="[0, 0]" />
        
        <!-- Header section - adjusted for new layout -->
        <Group id="headerGroup" translation="[30, 60]">
            <!-- Main title -->
            <Label text="Profile Settings" id="accountSettingsName" color="#4FC3F7" font="font:UrbanistBold" translation="[0, 0]" >
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="56" />
            </Label>
            
            <!-- Subtitle -->
            <Label text="Manage your account and authentication" id="accountSubtitle" color="#CCCCCC" font="font:UrbanistMedium" translation="[0, 70]" >
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="28" />
            </Label>
        </Group>
        <!-- Authentication status card -->
        <Group id="authStatusCard" translation="[30, 180]">
            <!-- Card background -->
            <Rectangle
                id="statusCardBg"
                width="600"
                height="120"
                color="#1a1f2e"
                translation="[0, 0]" />
            
            <!-- Status indicator -->
            <Rectangle
                id="statusIndicator"
                width="8"
                height="120"
                color="#4FC3F7"
                translation="[0, 0]" />
            
            <!-- Status content -->
            <Group id="statusContent" translation="[30, 20]">
                <Label text="Authentication Status" id="statusTitle" color="#FFFFFF" font="font:UrbanistBold" translation="[0, 0]" >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="28" />
                </Label>
                <Label text="Not authenticated" id="statusValue" color="#CCCCCC" font="font:UrbanistMedium" translation="[0, 40]" >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="24" />
                </Label>
                <Label text="Press OK to manage authentication" id="statusHint" color="#888888" font="font:UrbanistMedium" translation="[0, 70]" >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
                </Label>
            </Group>
        </Group>

        <!-- Logout action card -->
        <Group id="logoutGroup" translation="[30, 330]" focusable="true">
            <!-- Card background -->
            <Rectangle
                id="logoutCardBg"
                width="600"
                height="100"
                color="#1a1f2e"
                translation="[0, 0]" />
            
            <!-- Focus border -->
            <Poster
                id="logoutFocusBorder"
                uri="pkg:/images/png/button_focused_2px.9.png"
                blendColor="0x6366f1FF"
                width="600"
                height="100"
                translation="[0, 0]"
                visible="false" />
            
            <!-- Action content -->
            <Group id="logoutContent" translation="[30, 20]">
                <Poster
                    id="logoutIcon"
                    uri="pkg:/images/png/logout.png"
                    width="60"
                    height="60"
                    translation="[0, 0]" 
                    loadDisplayMode="scaleToZoom" />
                
                <Label text="Log Out" id="logoutText" color="#FFFFFF" font="font:UrbanistBold" translation="[80, 8]" >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
                </Label>
                
                <Label text="Sign out of your account" id="logoutDesc" color="#CCCCCC" font="font:UrbanistMedium" translation="[80, 45]" >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
                </Label>
            </Group>
        </Group>

        <!-- Login action card -->
        <Group id="loginGroup" translation="[30, 330]" visible="false" focusable="true">
            <!-- Card background -->
            <Rectangle
                id="loginCardBg"
                width="600"
                height="100"
                color="#1a1f2e"
                translation="[0, 0]" />
            
            <!-- Focus border -->
            <Poster
                id="loginFocusBorder"
                uri="pkg:/images/png/button_focused_2px.9.png"
                blendColor="0x6366f1FF"
                width="600"
                height="100"
                translation="[0, 0]"
                visible="false" />
            
            <!-- Action content -->
            <Group id="loginContent" translation="[30, 20]">
                <Poster
                    id="loginIcon"
                    uri="pkg:/images/png/login.png"
                    width="60"
                    height="60"
                    translation="[0, 0]" 
                    loadDisplayMode="scaleToZoom" />
                
                <Label text="Log In" id="loginText" color="#FFFFFF" font="font:UrbanistBold" translation="[80, 8]" >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
                </Label>
                
                <Label text="Sign in to your account" id="loginDesc" color="#CCCCCC" font="font:UrbanistMedium" translation="[80, 45]" >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
                </Label>
            </Group>
        </Group>
        
        <!-- Additional info section -->
        <Group id="infoSection" translation="[30, 480]">
            <Label text="Profile Information" id="infoTitle" color="#4FC3F7" font="font:UrbanistBold" translation="[0, 0]" >
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="38" />
            </Label>
            
            <!-- Info cards -->
            <Group id="infoCards" translation="[0, 50]">
                <!-- App version card -->
                <Rectangle
                    id="versionCardBg"
                    width="280"
                    height="80"
                    color="#1a1f2e"
                    translation="[0, 0]" />
                
                <Group id="versionContent" translation="[20, 15]">
                    <Label text="App Version" id="versionLabel" color="#CCCCCC" font="font:UrbanistMedium" translation="[0, 0]" >
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
                    </Label>
                    <Label text="v1.0.0" id="versionValue" color="#FFFFFF" font="font:UrbanistBold" translation="[0, 28]" >
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="24" />
                    </Label>
                </Group>
                
                <!-- Device info card -->
                <Rectangle
                    id="deviceCardBg"
                    width="280"
                    height="80"
                    color="#1a1f2e"
                    translation="[300, 0]" />
                
                <Group id="deviceContent" translation="[320, 15]">
                    <Label text="Device" id="deviceLabel" color="#CCCCCC" font="font:UrbanistMedium" translation="[0, 0]" >
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
                    </Label>
                    <Label text="Roku Device" id="deviceValue" color="#FFFFFF" font="font:UrbanistBold" translation="[0, 28]" >
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="24" />
                    </Label>
                </Group>
            </Group>
        </Group>
        
        <!-- USER PROFILE SECTION (Right side - only visible when authenticated) -->
        <Group id="userProfileSection" translation="[700, 60]" visible="false">
            <!-- Section title (same style as Profile Settings) -->
            <Label text="Profile Details" id="accountDetailsTitle" color="#4FC3F7" font="font:UrbanistBold" translation="[0, 0]">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="56" />
            </Label>
            
            <!-- Subtitle -->
            <Label text="Your profile information" id="accountDetailsSubtitle" color="#CCCCCC" font="font:UrbanistMedium" translation="[0, 70]">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="28" />
            </Label>
            
            <!-- Profile card background -->
            <Rectangle
                id="profileCardBg"
                width="700"
                height="460"
                color="#1a1f2e"
                translation="[0, 120]" />
            
            <!-- Profile accent bar -->
            <Rectangle
                id="profileAccentBar"
                width="700"
                height="6"
                color="#4FC3F7"
                translation="[0, 120]" />
            
            <!-- Profile header -->
            <Group id="profileHeader" translation="[30, 150]">
                <!-- Avatar circle -->
                <Rectangle
                    id="avatarBg"
                    width="80"
                    height="80"
                    color="#4FC3F7"
                    translation="[0, 0]" />
                
                <Label id="avatarInitials" text="GB" color="#0f1419" font="font:UrbanistBold" translation="[16, 18]">
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="36" />
                </Label>
                
                <!-- User name next to avatar -->
                <Label id="profileFullName" text="George Bokuchava" color="#FFFFFF" font="font:UrbanistBold" translation="[100, 10]">
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="36" />
                </Label>
                
                <Label id="profileWelcome" text="Welcome back!" color="#4FC3F7" font="font:UrbanistMedium" translation="[100, 52]">
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
                </Label>
            </Group>
            
            <!-- Divider line -->
            <Rectangle
                id="profileDivider"
                width="640"
                height="2"
                color="#2a3142"
                translation="[30, 250]" />
            
            <!-- User details -->
            <Group id="userDetails" translation="[30, 280]">
                <!-- Email row -->
                <Group id="emailRow" translation="[0, 0]">
                    <Poster
                        id="emailIcon"
                        uri="pkg:/images/png/email_icon.png"
                        width="32"
                        height="32"
                        translation="[0, 5]"
                        loadDisplayMode="scaleToFit"
                        blendColor="#4FC3F7" />
                    
                    <Label id="emailLabel" text="Email" color="#888888" font="font:UrbanistMedium" translation="[50, 0]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
                    </Label>
                    
                    <Label id="emailValue" text="gb@tulix.com" color="#FFFFFF" font="font:UrbanistMedium" translation="[50, 28]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26" />
                    </Label>
                </Group>
                
                <!-- Name row -->
                <Group id="nameRow" translation="[0, 80]">
                    <Poster
                        id="userIcon"
                        uri="pkg:/images/png/user_icon.png"
                        width="32"
                        height="32"
                        translation="[0, 5]"
                        loadDisplayMode="scaleToFit"
                        blendColor="#4FC3F7" />
                    
                    <Label id="nameLabel" text="Full Name" color="#888888" font="font:UrbanistMedium" translation="[50, 0]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
                    </Label>
                    
                    <Label id="nameValue" text="George Bokuchava" color="#FFFFFF" font="font:UrbanistMedium" translation="[50, 28]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26" />
                    </Label>
                </Group>
                
                <!-- Subscription status row -->
                <Group id="subscriptionRow" translation="[0, 160]">
                    <Poster
                        id="subscriptionIcon"
                        uri="pkg:/images/png/subscription_icon.png"
                        width="32"
                        height="32"
                        translation="[0, 5]"
                        loadDisplayMode="scaleToFit"
                        blendColor="#4FC3F7" />
                    
                    <Label id="subscriptionLabel" text="Payment Method" color="#888888" font="font:UrbanistMedium" translation="[50, 0]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
                    </Label>
                    
                    <Label id="subscriptionValue" text="Not Set Up" color="#FF6B6B" font="font:UrbanistBold" translation="[50, 28]">
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="26" />
                    </Label>
                </Group>
                
                <!-- User ID row -->
                <Group id="userIdRow" translation="[0, 240]">
                    <Poster
                        id="idIcon"
                        uri="pkg:/images/png/id_icon.png"
                        width="32"
                        height="32"
                        translation="[0, 5]"
                        loadDisplayMode="scaleToFit"
                        blendColor="#4FC3F7" />
                    
                    <Label id="userIdLabel" text="Profile ID" color="#888888" font="font:UrbanistMedium" translation="[50, 0]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
                    </Label>
                    
                    <Label id="userIdValue" text="#10120" color="#FFFFFF" font="font:UrbanistMedium" translation="[50, 28]">
                        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26" />
                    </Label>
                </Group>
            </Group>
        </Group>
    </children>
</component>