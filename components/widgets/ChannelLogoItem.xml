<?xml version="1.0" encoding="utf-8" ?>
<component name="ChannelLogoItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged"/>
    </interface>
    
    <script type="text/brightscript" uri="ChannelLogoItem.brs" />
    
    <children>
        <!-- Background -->
        <Rectangle
            id="itemBg"
            width="300"
            height="70"
            color="#1F3B5C"
            opacity="0.8" />
        
        <!-- Channel logo (left side, smaller) -->
        <Poster
            id="channelLogo"
            translation="[5, 10]"
            width="80"
            height="50"
            loadDisplayMode="scaleToFit"
            failedBitmapUri=""
            loadingBitmapUri=""
            visible="true" />
        
        <!-- Channel name (right side, always visible) -->
        <Label
            id="channelName"
            text=""
            translation="[95, 5]"
            width="200"
            height="60"
            color="#FFFFFF"
            horizAlign="left"
            vertAlign="center"
            wrap="true"
            maxLines="2">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
        </Label>
    </children>
</component>
