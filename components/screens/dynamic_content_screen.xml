<?xml version="1.0" encoding="utf-8" ?>
<component name="dynamic_content_screen" extends="Group" focusable="true">
  <script type="text/brightscript" uri="pkg:/components/screens/dynamic_content_screen.brs" />
  <script type="text/brightscript" uri="pkg:/components/helpers/ContentItemHelper.brs" />
  <interface>
    <field id="contentTypeId" type="int" value="-1" onChange="loadContentForType"/>
    <field id="contentData" type="array" />
    <field id="isLoading" type="bool" value="false" />
    <field id="explicitContentFocusRequested" type="int" value="0" onChange="onExplicitContentFocusRequested" />
    <field id="dvrRequested" type="assocarray" />
    <field id="videoPlayRequested" type="assocarray" />
    <field id="isExpanded" type="bool" value="false" onChange="onExpandedChanged"/>
    <field id="visible" type="bool" value="true" onChange="onVisibleChanged"/>
    <field id="restoreFocusRequested" type="bool" value="false" onChange="onRestoreFocusRequested"/>
  </interface>
  <children>
    <!-- Content Expand/Collapse Animations -->
    <Animation id="expandRowListAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="expandRowListInterp" key="[0.0, 1.0]" keyValue="[[20, 20], [-120, 20]]" fieldToInterp="contentRowList.translation"/>
    </Animation>
    <Animation id="collapseRowListAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="collapseRowListInterp" key="[0.0, 1.0]" keyValue="[[-120, 20], [20, 20]]" fieldToInterp="contentRowList.translation"/>
    </Animation>
    <Animation id="expandGridAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="expandGridInterp" key="[0.0, 1.0]" keyValue="[[40, 175], [-100, 175]]" fieldToInterp="userChannelsGrid.translation"/>
    </Animation>
    <Animation id="collapseGridAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="collapseGridInterp" key="[0.0, 1.0]" keyValue="[[-100, 175], [40, 175]]" fieldToInterp="userChannelsGrid.translation"/>
    </Animation>
    <Animation id="expandHeaderAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="expandHeaderInterp" key="[0.0, 1.0]" keyValue="[[25, 10], [-115, 10]]" fieldToInterp="screenHeaderGroup.translation"/>
    </Animation>
    <Animation id="collapseHeaderAnimation" duration="0.25" easeFunction="outCubic">
      <Vector2DFieldInterpolator id="collapseHeaderInterp" key="[0.0, 1.0]" keyValue="[[-115, 10], [25, 10]]" fieldToInterp="screenHeaderGroup.translation"/>
    </Animation>

    <!-- Background - adjusted for wider 240px nav bar -->
    <Rectangle
      id="backgroundRect"
      width="1740"
      height="1080"
      color="#0f1419"
      translation="[0, 0]" />
    
    <!-- Screen Header with Tab Name and Branding (for Live TV, Age Restricted, etc.) -->
    <Group id="screenHeaderGroup" translation="[25, 15]" visible="false">
      <!-- Left side: Tab Name • Timestamp -->
      <Group id="headerLeftGroup" translation="[0, 0]">
        <!-- Tab Name (e.g., "Movies") -->
        <Label
          id="screenTabName"
          text="Live TV"
          color="#ffffff"
          font="font:UrbanistBold"
          horizAlign="left"
          vertAlign="center"
          translation="[0, 42]"
          height="36">
          <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
        </Label>
        
        <!-- Dot Separator (closer to title) -->
        <Label
          id="screenDotSeparator"
          text="•"
          color="#6366f1"
          font="font:UrbanistBold"
          horizAlign="center"
          vertAlign="center"
          translation="[95, 42]"
          width="20"
          height="36">
          <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
        </Label>
        
        <!-- Local Time Display -->
        <Label
          id="screenTimeLabel"
          text="00:00"
          color="#ffffff"
          font="font:UrbanistMedium"
          horizAlign="left"
          vertAlign="center"
          translation="[115, 44]"
          height="32">
          <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26" />
        </Label>
      </Group>
      
      <!-- Right side: GiaTV Logo (120x120, positioned at right edge - will be visible when content expands) -->
      <Poster
        id="screenBrandIcon"
        uri="pkg:/images/img/gia-tv-small.png"
        width="120"
        height="120"
        translation="[1710, 0]"
        loadDisplayMode="scaleToFit" />
      
      <!-- Header Divider Line -->
      <Rectangle
        id="headerDivider"
        width="1850"
        height="2"
        color="0x3A4A6AFF"
        translation="[0, 125]" />
    </Group>
    
    <!-- Loading indicator -->
    <Group id="loadingGroup" translation="[890, 540]" visible="false">
      <Label
        id="loadingLabel"
        text="Loading content..."
        color="#ffffff"
        font="font:UrbanistMedium"
        horizAlign="center"
        translation="[-100, 0]"
        width="200">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="24" />
      </Label>
    </Group>
    
    <!-- RowList for content display with automatic scrolling -->
    <RowList
      id="contentRowList"
      translation="[20, 20]"
      visible="true"
      itemComponentName="RowListItemComponent"
      itemSpacing="[0, 60]"
      rowItemSpacing="[20, 15]"
      rowLabelOffset="[0, 15]"
      showRowLabel="true"
      showRowCounter="true"
      numRows="10"
      rowFocusAnimationStyle="fixedFocus"
      rowItemSize="[280, 420]"
      width="1500"
      rowCounterRightOffset="80"
      height="1000" />
    
    <!-- Dedicated RowList for Personal page (M3U items) -->
    <RowList
      id="personalRowList"
      translation="[20, 20]"
      visible="false"
      itemComponentName="DVRItemComponent"
      itemSpacing="[0, 40]"
      rowItemSpacing="[30, 15]"
      rowLabelOffset="[0, 15]"
      showRowLabel="true"
      showRowCounter="true"
      numRows="10"
      rowFocusAnimationStyle="fixedFocus"
      rowItemSize="[400, 300]"
      rowHeights="[320]"
      width="1500"
      rowCounterRightOffset="80"
      height="1000" />
    
    <!-- GridView for User Channels (landscape grid layout) -->
    <MarkupGrid
      id="userChannelsGrid"
      translation="[40, 175]"
      visible="false"
      focusable="true"
      itemComponentName="SeriesItemComponent"
      numColumns="5"
      numRows="4"
      itemSpacing="[20, 30]"
      itemSize="[350, 245]"
      vertFocusAnimationStyle="fixedFocus"
      drawFocusFeedback="true"
      drawFocusFeedbackOnTop="true"
      width="1500"
      rowCounterRightOffset="80"
      height="900" />

      <!-- focusBitmapBlendColor="#4FC3F7" -->

    
    <!-- Static Personal Page Content (Hardcoded M3U Item) -->
    <Group id="personalStaticGroup" translation="[20, 150]" visible="false">
      <!-- Row Label -->
      <Label
        id="personalRowLabel"
        text="Shared Channels"
        color="#ffffff"
        font="font:UrbanistBold"
        horizAlign="left"
        vertAlign="top"
        translation="[0, 0]"
        width="400"
        height="40">
        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="28" />
      </Label>
      
      <!-- M3U Playlist Card (Hardcoded) -->
      <Group id="m3uCardGroup" translation="[0, 60]" focusable="true">
        <!-- Card Background -->
        <Rectangle
          id="m3uCardBackground"
          width="350"
          height="197"
          color="0x2A3F5EFF"/>
        
        <!-- Logo (Centered) -->
        <Poster
          id="m3uLogo"
          uri="pkg:/images/png/gia-tv-logo.png"
          width="150"
          height="150"
          translation="[100, 23]"
          loadDisplayMode="scaleToFit"
          failedBitmapUri="pkg:/images/png/gia-tv-logo.png"/>
        
        <!-- Focus Indicator (Standard outline) -->
        <Rectangle
          id="m3uFocusIndicator"
          width="350"
          height="197"
          color="#f16667"
          translation="[0, 0]"
          opacity="0"/>
        
        <!-- Title Below Card (Only title shown) -->
        <Label
          id="m3uBottomTitle"
          text="M3U Channels"
          width="350"
          height="40"
          translation="[0, 203]"
          color="0xCCCCCCFF"
          font="font:TinyBoldSystemFont"
          horizAlign="left"
          vertAlign="top"
          maxLines="2"
          ellipsisText="..."/>
      </Group>
    </Group>
    
    <!-- No content message -->
    <Group id="noContentGroup" translation="[0, 0]" visible="false">
      <!-- GIA.TV Logo -->
      <Poster
        id="giaLogo"
        uri="pkg:/images/png/gia-tv-big.png"
        width="512"
        height="512"
        translation="[634, 150]"
        loadDisplayMode="scaleToFit"
        opacity="0.8" />
      
      <!-- No content message -->
      <Label
        id="noContentLabel"
        text="Series not available for now"
        color="#ffffff"
        font="font:UrbanistSemiBold"
        horizAlign="center"
        translation="[540, 720]"
        width="700">
        <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="42" />
      </Label>
      
      <!-- Secondary message -->
      <Label
        id="noContentSubLabel"
        text="Check back later for new series content"
        color="#cccccc"
        font="font:UrbanistMedium"
        horizAlign="center"
        translation="[540, 780]"
        width="700">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="28" />
      </Label>
    </Group>
  </children>
</component>
