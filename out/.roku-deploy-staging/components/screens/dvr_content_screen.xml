<?xml version="1.0" encoding="utf-8" ?>
<component name="dvr_content_screen" extends="Group" focusable="true">
  <script type="text/brightscript" uri="pkg:/components/screens/dvr_content_screen.brs" />
  <interface>
    <field id="dvrUrl" type="string" value="" onChange="loadDVRContent"/>
    <field id="channelTitle" type="string" value="" />
    <field id="isLoading" type="bool" value="false" />
  </interface>
  <children>
    <!-- Background -->
    <Rectangle
      id="backgroundRect"
      width="1740"
      height="1080"
      color="#0f1419"
      translation="[0, 0]" />
    
    <!-- Header with Channel Info -->
    <Group id="headerGroup" translation="[40, 40]">
      <!-- Back Button -->
      <Group id="backButton" translation="[0, 0]" focusable="true">
        <Rectangle
          id="backButtonBg"
          width="120"
          height="50"
          color="#6366f1"
          translation="[0, 0]"
        />
        <Label
          id="backButtonText"
          text="← Back"
          color="#FFFFFF"
          horizAlign="center"
          vertAlign="center"
          font="font:UrbanistBold"
          translation="[0, 0]"
          width="120"
          height="50"
        >
          <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="18" />
        </Label>
      </Group>
      
      <!-- Channel Title -->
      <Label
        id="channelTitleLabel"
        text="DVR Content"
        color="#FFFFFF"
        horizAlign="left"
        vertAlign="center"
        font="font:UrbanistBold"
        translation="[150, 0]"
        width="600"
        height="50"
      >
        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
      </Label>
      
      <!-- DVR Info -->
      <Label
        id="dvrInfoLabel"
        text="Available recordings and programs"
        color="#CCCCCC"
        horizAlign="left"
        vertAlign="center"
        font="font:UrbanistMedium"
        translation="[150, 55]"
        width="600"
        height="25"
      >
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
      </Label>
    </Group>
    
    <!-- Loading indicator -->
    <Group id="loadingGroup" translation="[890, 540]" visible="false">
      <Label
        id="loadingLabel"
        text="Loading DVR content..."
        color="#ffffff"
        font="font:UrbanistMedium"
        horizAlign="center"
        translation="[-150, 0]"
        width="300">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="24" />
      </Label>
    </Group>
    
    <!-- DVR Content RowList -->
    <RowList
      id="dvrRowList"
      translation="[40, 140]"
      visible="true"
      itemComponentName="DVRItemComponent"
      itemSpacing="[0, 40]"
      rowItemSpacing="[[30, 15]]"
      rowLabelOffset="[[0, 15]]"
      showRowLabel="[true]"
      showRowCounter="[false]"
      numRows="10"
      rowFocusAnimationStyle="fixedFocus"
      rowItemSize="[[520, 390]]"
      width="1700"
      height="900" />
    
    <!-- No DVR content message -->
    <Group id="noDVRContentGroup" translation="[0, 0]" visible="false">
      <!-- DVR Logo/Icon -->
      <Rectangle
        id="dvrIconBg"
        width="120"
        height="120"
        color="#6366f1"
        translation="[830, 300]"
      />
      <Label
        id="dvrIconText"
        text="DVR"
        color="#FFFFFF"
        font="font:UrbanistBold"
        horizAlign="center"
        vertAlign="center"
        translation="[830, 300]"
        width="120"
        height="120"
      >
        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
      </Label>
      
      <!-- No DVR content message -->
      <Label
        id="noDVRContentLabel"
        text="No DVR content available"
        color="#ffffff"
        font="font:UrbanistSemiBold"
        horizAlign="center"
        translation="[540, 480]"
        width="700">
        <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="42" />
      </Label>
      
      <!-- Secondary message -->
      <Label
        id="noDVRContentSubLabel"
        text="Check back later for recorded programs"
        color="#cccccc"
        font="font:UrbanistMedium"
        horizAlign="center"
        translation="[540, 540]"
        width="700">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="28" />
      </Label>
    </Group>
  </children>
</component>