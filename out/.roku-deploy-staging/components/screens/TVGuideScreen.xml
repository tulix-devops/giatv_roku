<?xml version="1.0" encoding="utf-8" ?>
<component name="TVGuideScreen" extends="Group">
    <interface>
        <field id="visible" type="bool" value="false" onChange="onVisibleChanged" />
        <field id="contentTypeId" type="int" value="0" onChange="onContentTypeIdChanged" />
        <field id="explicitContentFocusRequested" type="bool" value="false" onChange="onExplicitFocusRequested" />
        <field id="videoPlayRequested" type="assocarray" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/TVGuideScreen.brs" />

    <children>
        <!-- Background -->
        <Rectangle 
            id="background" 
            width="1920" 
            height="1080" 
            color="#0D1B2A" />

        <!-- TOP LEFT: Back Navigation Hint -->
        <Label id="backHint" 
               text="Press BACK for Navigation"
               translation="[40, 30]"
               width="400"
               height="20"
               font="font:SmallSystemFont"
               color="#4FC3F7"
               horizAlign="left"
               vertAlign="center" />

        <!-- TOP LEFT: Current Channel Logo (Smaller) -->
        <Group id="channelLogoGroup" translation="[40, 80]">
            <Rectangle id="channelLogoBg" 
                       width="320" 
                       height="180" 
                       color="#1F3B5C"
                       opacity="0.5" />
            <Poster id="channelLogoImage"
                    uri=""
                    translation="[0, 0]"
                    width="320"
                    height="180"
                    loadingBitmapUri=""
                    failedBitmapUri="" />
            <Label id="channelLogoName"
                   text=""
                   translation="[0, 0]"
                   width="240"
                   height="135"
                   font="font:SmallBoldSystemFont"
                   color="#FFFFFF"
                   horizAlign="center"
                   vertAlign="center"
                   visible="false" />
        </Group>
        
        <!-- PROGRAM DETAILS: Smaller container -->
        <Group id="programDetailsGroup" translation="[40, 280]">
            <Rectangle id="detailsBg" 
                       width="400" 
                       height="340" 
                       color="#1F3B5C"
                       opacity="0.5" />
            
            <!-- Current Timestamp (at the top) -->
            <Label id="currentTimestamp" 
                   text="00:00 AM"
                   translation="[20, 15]"
                   width="360"
                   height="25"
                   font="font:SmallBoldSystemFont"
                   color="#4FC3F7"
                   horizAlign="left"
                   vertAlign="center" />
            
            <Label id="programTitle" 
                   text=""
                   translation="[20, 50]"
                   width="360"
                   height="90"
                   font="font:MediumBoldSystemFont"
                   color="#FFFFFF"
                   horizAlign="left"
                   vertAlign="top"
                   wrap="true"
                   maxLines="3" />
            <Label id="programTime" 
                   text=""
                   translation="[20, 150]"
                   width="360"
                   height="30"
                   font="font:SmallSystemFont"
                   color="#B0B8C4"
                   horizAlign="left"
                   vertAlign="center" />
            <Label id="programDescription" 
                   text=""
                   translation="[20, 190]"
                   width="360"
                   height="150"
                   font="font:TinySystemFont"
                   color="#B0B8C4"
                   horizAlign="left"
                   vertAlign="top"
                   wrap="true"
                   maxLines="5" />
        </Group>

        <!-- VIDEO PLAYER: Right side -->
        <Group id="videoPlayerGroup" translation="[480, 0]">
            <Rectangle id="videoPlayerBg" 
                       width="1440" 
                       height="680" 
                       color="#000000"
                       opacity="1.0" />
            <Video id="videoPlayer"
                   translation="[0, 0]"
                   width="1440"
                   height="680"
                   visible="true"
                   loop="false"
                   control="stop"
                   enableUI="false" />
            <Label id="videoPlayerStatus"
                   text=""
                   translation="[0, 0]"
                   width="1440"
                   height="680"
                   font="font:MediumSystemFont"
                   color="#FFFFFF"
                   horizAlign="center"
                   vertAlign="center"
                   visible="false" />
        </Group>

        <!-- TV GUIDE GRID (TimeGrid Component) - Bottom full-width layout -->
        <TimeGrid
            id="timeGrid"
            translation="[0, 680]"
            width="1920"
            height="415"
            visible="true"
            focusable="true"
            channelInfoComponentName="EPGChannelItem"
            numRows="5"
            fillProgramGaps="true"
            showPastTimeScreen="false"
            duration="9000"
            maxDays="1"
            channelInfoWidth="160"
            programInfoBackgroundColor="#1F3B5C"
            programInfoFocusedBackgroundColor="#4FC3F7"
            timeBarHeight="40"
            timeBarTextColor="#FFFFFF"
            timeBarBackgroundColor="#1F3B5C"
            gridBackgroundColor="#0D1B2A"
            channelInfoBackgroundColor="#1F3B5C"
            channelNoDataText=""
            loadingDataText="TV Guide Loading..."
            nowBarBlendColor="#FF0000"
            nowBarThickness="3"
            nowBarWidth="10"
            nowBarOffset="10"
            minimumNowBarOffset="355" />
    </children>
</component>
