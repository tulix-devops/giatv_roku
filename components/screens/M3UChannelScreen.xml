<?xml version="1.0" encoding="utf-8" ?>
<component name="M3UChannelScreen" extends="Group" focusable="true">
    <interface>
        <field id="m3uUrl" type="string" onChange="onM3uUrlChanged"/>
        <field id="videoPlayRequested" type="assocarray" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/M3UChannelScreen.brs"/>

    <children>
        <!-- Background -->
        <Rectangle
            id="backgroundRect"
            width="1920"
            height="1080"
            color="#0f1419"
            translation="[0, 0]"/>

        <!-- Screen Header with Tab Name and Branding -->
        <Group id="screenHeaderGroup" translation="[25, 15]" visible="true">
            <!-- Left side: Tab Name • Timestamp -->
            <Group id="headerLeftGroup" translation="[0, 0]">
                <!-- Tab Name -->
                <Label
                    id="screenTabName"
                    text="M3U Channels"
                    color="#ffffff"
                    font="font:UrbanistBold"
                    horizAlign="left"
                    vertAlign="center"
                    translation="[0, 42]"
                    height="36">
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32"/>
                </Label>
                
                <!-- Dot Separator -->
                <Label
                    id="screenDotSeparator"
                    text="•"
                    color="#6366f1"
                    font="font:UrbanistBold"
                    horizAlign="center"
                    vertAlign="center"
                    translation="[260, 42]"
                    width="20"
                    height="36">
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32"/>
                </Label>
                
                <!-- Local Time Display -->
                <Label
                    id="screenTimeLabel"
                    text="00:00"
                    color="#ffffff"
                    font="font:UrbanistMedium"
                    horizAlign="left"
                    vertAlign="center"
                    translation="[280, 44]"
                    height="32">
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26"/>
                </Label>
            </Group>
            
            <!-- Right side: GiaTV Logo -->
            <Poster
                id="screenBrandIcon"
                uri="pkg:/images/img/gia-tv-small.png"
                width="120"
                height="120"
                translation="[1710, 0]"
                loadDisplayMode="scaleToFit"/>
            
            <!-- Header Divider Line -->
            <Rectangle
                id="headerDivider"
                width="1850"
                height="2"
                color="0x3A4A6AFF"
                translation="[0, 125]"/>
        </Group>

        <!-- Loading indicator -->
        <Group id="loadingGroup" translation="[890, 540]" visible="true">
            <Label
                id="loadingLabel"
                text="Loading channels..."
                color="#ffffff"
                font="font:UrbanistMedium"
                horizAlign="center"
                translation="[-100, 0]"
                width="300">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26"/>
            </Label>
        </Group>

        <!-- Search Prompt (Left side) -->
        <Label
            id="searchPromptLabel"
            text="Press OPTIONS for Search"
            color="#6366f1"
            font="font:UrbanistMedium"
            horizAlign="left"
            vertAlign="center"
            translation="[25, 170]"
            width="300"
            height="30"
            visible="false">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="24"/>
        </Label>

        <!-- Search Status Display -->
        <Group id="searchStatusGroup" translation="[20, 155]" visible="false">
            <Label
                id="searchStatusLabel"
                text="Search: "
                color="#ffffff"
                font="font:UrbanistBold"
                horizAlign="left"
                vertAlign="center"
                translation="[5, 0]"
                width="115"
                height="30">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="26"/>
            </Label>
            <Label
                id="searchQueryText"
                text=""
                color="#4FC3F7"
                font="font:UrbanistMedium"
                horizAlign="left"
                vertAlign="center"
                translation="[100, 0]"
                width="400"
                height="30">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="28"/>
            </Label>
            <Label
                id="searchClearHint"
                text="(OPTIONS to search again, BACK to clear)"
                color="#888888"
                font="font:UrbanistMedium"
                horizAlign="left"
                vertAlign="center"
                translation="[5, 35]"
                width="600"
                height="25">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="24"/>
            </Label>
        </Group>

        <!-- Channel Count Display (Right side) -->
        <Label
            id="channelCountLabel"
            text="0 channels loaded"
            color="#ffffff"
            font="font:UrbanistBold"
            horizAlign="right"
            vertAlign="center"
            translation="[1475, 150]"
            width="400"
            height="40"
            visible="false">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="28"/>
        </Label>

        <!-- Selected Item Index Display -->
        <Label
            id="selectedIndexLabel"
            text="Item 1 selected"
            color="#cccccc"
            font="font:UrbanistMedium"
            horizAlign="right"
            vertAlign="center"
            translation="[1475, 190]"
            width="400"
            height="30"
            visible="false">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20"/>
        </Label>

        <!-- Animations -->
        <Animation id="gridFadeOut" duration="0.15" repeat="false" easeFunction="linear">
            <FloatFieldInterpolator key="[1.0, 0.0]" fieldToInterp="channelGridContainer.opacity"/>
        </Animation>
        <Animation id="gridFadeIn" duration="0.2" repeat="false" easeFunction="linear">
            <FloatFieldInterpolator key="[0.0, 1.0]" fieldToInterp="channelGridContainer.opacity"/>
        </Animation>
        
        <!-- Main Content Container (Left sidebar + Right grid) -->
        <Group id="contentContainer" translation="[25, 240]">
            
            <!-- Left Side: Category List -->
            <Group id="categoryListContainer" translation="[0, 10]">
                <LabelList
                    id="categoryLabelList"
                    translation="[0, 0]"
                    itemSize="[280, 35]"
                    numRows="20"
                    focusRow="0"
                    drawFocusFeedback="true"
                    focusBitmapUri="pkg:/images/png/shapes/button_unfocused.9.png"
                    focusFootprintBitmapUri="pkg:/images/png/shapes/button_unfocused.9.png"
                    color="0xFFFFFFFF"
                    focusedColor="0x3A4A6AFF"
                    font="font:SmallSystemFont"
                    focusedFont="font:SmallSystemFont"
                    vertFocusAnimationStyle="fixedFocus"
                    itemSpacing="[0, 35]"
                    sectionDividerLeftOffset="20"
                    visible="false"
                    wrap="false"/>
            </Group>
            
            <!-- Right Side: Channel Grid (4 columns) -->
            <Group id="channelGridContainer" translation="[330, 0]">
                <!-- Grid View for Channels -->
                <MarkupGrid
                    id="channelGrid"
                    translation="[0, 0]"
                    visible="false"
                    itemComponentName="M3UChannelItem"
                    vertFocusAnimationStyle="floatingFocus"
                    itemSize="[360, 250]"
                    numColumns="4"
                    numRows="3"
                    itemSpacing="[20, 20]"
                    drawFocusFeedback="true"/>

                <!-- Search Results Grid (same position, shows filtered results) -->
                <MarkupGrid
                    id="searchResultsGrid"
                    translation="[0, 0]"
                    visible="false"
                    itemComponentName="M3UChannelItem"
                    itemSize="[360, 250]"
                    numColumns="4"
                    numRows="3"
                    vertFocusAnimationStyle="floatingFocus"
                    itemSpacing="[20, 20]"
                    drawFocusFeedback="true"/>
                
                <!-- Preview Player Overlay (positioned over focused item) -->
                <Group id="previewPlayerContainer" translation="[0, 0]" visible="false">
                    <!-- Background for preview -->
                    <Rectangle
                        id="previewBackground"
                        width="360"
                        height="250"
                        color="#000000"
                        opacity="1.0"/>
                    
                    <!-- Preview Video Player (same size as grid item) -->
                    <Video
                        id="previewPlayer"
                        translation="[0, 0]"
                        width="360"
                        height="250"
                        visible="true"
                        loop="false"
                        enableUI="false"/>
                    
                    <!-- Status Messages Container (centered, full width) -->
                    <Group id="previewStatusGroup" translation="[0, 0]" visible="false">
                        <!-- Background for status -->
                        <Rectangle
                            width="360"
                            height="250"
                            color="#000000"
                            opacity="0.85"
                            translation="[0, 0]"/>
                        
                        <!-- Status Message (Loading / Error) -->
                        <Label
                            id="previewStatusLabel"
                            text="Loading Stream..."
                            color="#ffffff"
                            font="font:MediumBoldSystemFont"
                            horizAlign="center"
                            vertAlign="center"
                            translation="[0, 100]"
                            width="340"
                            height="50"
                            wrap="true"/>
                    </Group>
                    
                    <!-- LIVE indicator badge (bigger and more visible) -->
                    <Rectangle
                        id="liveIndicatorBg"
                        translation="[8, 8]"
                        width="80"
                        height="35"
                        color="#FF0000"
                        opacity="1.0"/>
                    <Label
                        id="liveIndicatorText"
                        text="● LIVE"
                        color="#ffffff"
                        font="font:MediumBoldSystemFont"
                        horizAlign="center"
                        vertAlign="center"
                        translation="[8, 8]"
                        width="80"
                        height="35">
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="20"/>
                    </Label>
                </Group>
            </Group>
        </Group>
        
        

        <!-- Clock Timer -->
        <Timer
            id="clockTimer"
            repeat="true"
            duration="60"/>
    </children>
</component>
