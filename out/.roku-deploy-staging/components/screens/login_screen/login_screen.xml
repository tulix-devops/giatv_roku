<?xml version="1.0" encoding="UTF-8" ?>
<component name="login_screen" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/screens/login_screen/login_screen.brs" />
    <interface>
        <field id="isNavigatedFromAccountTab" type="boolean"/>
    </interface>
    <children>
        <!-- Background with Gradient -->
        <Poster
            uri="pkg:/images/png/gradient.jpeg"
            width="1920"
            height="1080"
            loadDisplayMode="scaleToFill"
            translation="[0, 0]"/>
        
        <!-- Fallback gradient for smaller screens -->
        <Poster
            uri="pkg:/images/png/gradient720p.jpeg"
            width="1280"
            height="720"
            loadDisplayMode="scaleToFill"
            translation="[0, 0]"
            visible="false"
            id="gradient720p"/>
            
        <Group translation="[0, 0]" visible="true" scale="1" id="loginPage">
            <Label text="Welcome Back" color="0xFFFFFFFF" font="font:UrbanistSemiBold" translation="[1200, 50]" horizAlign="left" vertAlign="center">
                <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="48" />
            </Label>
            <Label text="Sign in to continue" color="0xCCCCCCFF" font="font:UrbanistRegular" translation="[1200, 100]" horizAlign="left" vertAlign="center">
                <Font role="font" uri="pkg:/images/UrbanistRegular.ttf" size="32" />
            </Label>
            <Poster
            uri="pkg:/images/png/logo-small.png"
            width="200"
            height="62"
            loadDisplayMode="scaleToZoom"
            translation="[1600, 60]"/>
            <Group id="nextButton" translation="[390, 470]" >
                <Poster 
                id="nextButtonShape"
                        uri="pkg:/images/png/shapes/pink_rounded.png"
                        width="300"
                        height="105" />
                <Label text="Next"  id="nextLabel" color="0xFFFFFF" font="font:UrbanistSemiBold" translation="[120, 30]" horizAlign="center" vertAlign="center" >
                    <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="36" />
                </Label>
            </Group>
            <Group id="cancelButton" translation="[60, 470]" >
                <Poster
                id="cancelButtonShape"
                        uri="pkg:/images/png/shapes/grey_rounded.png"
                        width="300"
                        height="105" />
                <Label text="Cancel"  id="cancelLabel" color="0xFFFFFF" font="font:UrbanistSemiBold" translation="[100, 30]" horizAlign="center" vertAlign="center" >
                    <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="36" />
                </Label>
            </Group>
        </Group>
        <Animation
            id="activateKeyboard"
            duration="0.3"
            repeat="false"
            easeFunction="linear"
        >
            <Vector2DFieldInterpolator
                id="translationInterpolator"
                key="[0.0, 1.0]"
                keyValue="[ [35, 1080], [35, 600] ]"
                fieldToInterp="keyboard.translation"
            />
        </Animation>
        <Animation
                id="deactivateKeyboard"
                duration="0.3"
                repeat="false"
                easeFunction="linear"
                >
            <Vector2DFieldInterpolator
                    id="translationInterpolator"
                    key="[0.0, 1.0]"
                    keyValue="[ [35, 600], [35, 1080]  ]"
                    fieldToInterp="keyboard.translation"
                />
        </Animation>
        <Group id="keyboardGroup" visible="true">
            <DynamicKeyboard
        id="loginKeyboard"
        showTextEditBox="false"
        translation="[35, 600]"
        focusable="true"
        visible="true" >
        
        </DynamicKeyboard>
            <VoiceTextEditBox
            id="voiceEmailBox"
            visible="false"
            ></VoiceTextEditBox>
            <VoiceTextEditBox
            id="voicePasswordBox"
            visible="false"
            ></VoiceTextEditBox>
            <TextEditBox  
            id="emailBox"
            translation="[75, 100]" 
            focusable="true"
            width="600" 
            height="120"
            hintText="Enter your email"
            hintTextColor="0xFFFFFFFF"
            text=""
            keyColor="0xDDDDDDFF"
            focusedKeyColor="0xFFFFFFFF"
            active="true"
            cursorColor="0xFFFFFFFF" />
            <Label text="Must not be empty"  id="emailBoxError" color="#FF0000" font="font:UrbanistSemiBold" translation="[690, 130]" horizAlign="center" vertAlign="center" visible="false">
                <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="36" />
            </Label>
            <Label text="Must not be empty"  id="passwordBoxError" color="#FF0000" font="font:UrbanistSemiBold" translation="[690, 280]" horizAlign="center" vertAlign="center" visible="false">
                <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="36" />
            </Label>
            <TextEditBox  
            id="passwordBox"
            translation="[75, 240]" 
            secureMode="true"
            focusable="true"
            width="600" 
            height="120"
            hintText="Enter your password"
            hintTextColor="0xFFFFFFFF"
            text=""
            keyColor="0xDDDDDDFF"
            focusedKeyColor="0xFFFFFFFF"
            cursorColor="0xFFFFFFFF" />
        </Group>
    </children>
</component>