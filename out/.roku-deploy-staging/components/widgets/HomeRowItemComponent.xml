<?xml version="1.0" encoding="UTF-8"?>
<component name="HomeRowItemComponent" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet" />
        <field id="focusPercent" type="float" onChange="onFocusChanged"/>
    </interface>
    <script type="text/brightscript" uri="HomeRowItemComponent.brs" />
    <children>
        <!-- PORTRAIT LAYOUT (for Movies) - 220x330 image + title -->
        <Group id="portraitLayout" visible="true">
            <Poster
                id="portraitPoster"
                uri=""
                width="220"
                height="330"
                translation="[0, 0]"
                loadDisplayMode="scaleToZoom"
                loadingBitmapUri="pkg:/images/png/poster_not_found_220x375.png"
                failedBitmapUri="pkg:/images/png/poster_not_found_220x375.png"
            />
            <!-- Live Badge for Portrait -->
            <Poster
                id="portraitLiveBadge"
                uri="pkg:/images/png/live_50x30_small_text.png"
                width="50"
                height="30"
                translation="[10, 10]"
                visible="false"
                loadDisplayMode="noScale"
            />
            <Label
                id="portraitTitle"
                text=""
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="top"
                font="font:TinyBoldSystemFont"
                translation="[0, 336]"
                width="220"
                height="36"
                maxLines="2"
                ellipsisText="..."
            />
        </Group>
        
        <!-- LANDSCAPE LAYOUT (for Series, Live TV, User Channels) - 350x197 image + title (4 per row + half peek) -->
        <Group id="landscapeLayout" visible="false">
            <Poster
                id="landscapePoster"
                uri=""
                width="350"
                height="197"
                translation="[0, 0]"
                loadDisplayMode="scaleToZoom"
                loadingBitmapUri="pkg:/images/png/poster_not_found_350x245.png"
                failedBitmapUri="pkg:/images/png/poster_not_found_350x245.png"
            />
            <!-- Live Badge for Landscape -->
            <Poster
                id="landscapeLiveBadge"
                uri="pkg:/images/png/live_50x30_small_text.png"
                width="50"
                height="30"
                translation="[10, 10]"
                visible="false"
                loadDisplayMode="noScale"
            />
            <Label
                id="landscapeTitle"
                text=""
                color="0xCCCCCCFF"
                horizAlign="left"
                vertAlign="top"
                font="font:TinyBoldSystemFont"
                translation="[0, 203]"
                width="350"
                height="40"
                maxLines="2"
                ellipsisText="..."
            />
        </Group>
    </children>
</component>