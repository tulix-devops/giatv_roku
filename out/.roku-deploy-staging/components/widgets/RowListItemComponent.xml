<?xml version="1.0" encoding="UTF-8"?>
<component name="RowListItemComponent" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet" />
    </interface>
    <script type="text/brightscript" uri="RowListItemComponent.brs" />
    <children>
        <Group>
            <!-- Modern Card Container with Focus Border -->
            <Rectangle
                id="cardBackground"
                width="280"
                height="420"
                color="0x1a1f2e"
                translation="[0, 0]"
            />
            
            
            <!-- Main Poster with Portrait Aspect Ratio -->
            <Poster
              id="poster"
              uri=""
              width="276"
              height="350"
              translation="[2, 2]"
              loadDisplayMode="scaleToZoom"
            />
            
            <!-- Modern Content Info Overlay -->
            <Group id="contentOverlay" translation="[2, 352]">
                <!-- Modern Dark Background -->
                <Rectangle
                    id="overlayBackground"
                    width="276"
                    height="66"
                    color="0x0f1419"
                    translation="[0, 0]"
                />
                
                <!-- Title - Enhanced Size -->
                <Label
                    id="titleLabel"
                    text=""
                    color="0xFFFFFF"
                    horizAlign="left"
                    vertAlign="top"
                    font="font:UrbanistBold"
                    translation="[12, 8]"
                    width="250"
                    height="28"
                    numLines="1"
                    ellipsizeTextOnBoundary="true"
                >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="20" />
                </Label>
                
                <!-- Description/Year - Enhanced Size -->
                <Label
                    id="descriptionLabel"
                    text=""
                    color="0xE5E5E5"
                    horizAlign="left"
                    vertAlign="top"
                    font="font:UrbanistMedium"
                    translation="[12, 32]"
                    width="220"
                    height="20"
                    numLines="1"
                >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="14" />
                </Label>
                
                <!-- Rating/Duration -->
                <Label
                    id="metaLabel"
                    text=""
                    color="0xE5E5E5"
                    horizAlign="left"
                    vertAlign="top"
                    font="font:UrbanistRegular"
                    translation="[12, 50]"
                    width="150"
                    height="16"
                    numLines="1"
                >
                    <Font role="font" uri="pkg:/images/UrbanistRegular.ttf" size="12" />
                </Label>
                
                <!-- Status Indicators Container -->
                <Group id="statusContainer" translation="[230, 8]">
                    <!-- HD Indicator -->
                    <Rectangle
                        id="hdIndicator"
                        width="35"
                        height="18"
                        color="0xFFD700"
                        translation="[0, 0]"
                        visible="false"
                    />
                    <Label
                        id="hdLabel"
                        text="HD"
                        color="0x000000"
                        horizAlign="center"
                        vertAlign="center"
                        font="font:UrbanistBold"
                        translation="[0, 0]"
                        width="35"
                        height="18"
                        visible="false"
                    >
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="10" />
                    </Label>
                    
                    <!-- New Indicator -->
                    <Rectangle
                        id="newIndicator"
                        width="35"
                        height="18"
                        color="0x4FC3F7"
                        translation="[0, 22]"
                        visible="false"
                    />
                    <Label
                        id="newLabel"
                        text="NEW"
                        color="0xFFFFFF"
                        horizAlign="center"
                        vertAlign="center"
                        font="font:UrbanistBold"
                        translation="[0, 22]"
                        width="35"
                        height="18"
                        visible="false"
                    >
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="9" />
                    </Label>
                </Group>
            </Group>

            
            <!-- Modern Play Button Overlay - Centered for portrait -->
            <Group id="playButtonGroup" translation="[118, 155]" visible="false">
                <Rectangle
                    id="playButtonBg"
                    width="44"
                    height="44"
                    color="0x6366f1"
                    translation="[0, 0]"
                />
                <Poster
                    id="playButton"
                    uri="pkg:/images/png/play-icon.png"
                    width="24"
                    height="24"
                    translation="[10, 10]"
                    loadDisplayMode="scaleToFit"
                />
            </Group>
            
            <!-- Loading State -->
            <Group id="loadingGroup" translation="[128, 165]" visible="false">
                <Rectangle
                    id="loadingBg"
                    width="24"
                    height="24"
                    color="0x6366f1"
                    opacity="0.8"
                    translation="[0, 0]"
                />
                <Label
                    id="loadingText"
                    text="..."
                    color="0xFFFFFF"
                    horizAlign="center"
                    vertAlign="center"
                    translation="[0, 0]"
                    width="24"
                    height="24"
                >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="12" />
                </Label>
            </Group>
        </Group>
    </children>
</component>