<?xml version="1.0" encoding="UTF-8"?>
<component name="SearchItemComponent" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet" />
    </interface>
    <script type="text/brightscript" uri="SearchItemComponent.brs" />
    <children>
        <Group>
            <!-- Main Poster with Rounded Corners Effect -->
            <Poster
              id="poster"
              width="300"
              height="420"
              loadDisplayMode="scaleToZoom"
            />
            
            <!-- Floating Info Panel - Simplified for Mixed Content -->
            <Group id="infoPanel" translation="[0, 300]">
                <!-- Main Background with Glass Effect -->
                <Rectangle
                    id="glassBackground"
                    width="303"
                    height="130" 
                    color="0x0A0A0A" 
                    opacity="0.92"
                    translation="[0, 0]"
                />
                
                <!-- Glass Reflection Effect -->
                <Rectangle
                    id="glassReflection"
                    width="305"
                    height="20"
                    color="0xFFFFFF"
                    opacity="0.1"
                    translation="[0, 0]"
                />
                
                <!-- Title with Glow Effect -->
                <Label
                    id="titleLabel"
                    color="0xFFFFFF"
                    text=""
                    horizAlign="left"
                    vertAlign="top"
                    font="font:UrbanistBold"
                    numLines="1"
                    translation="[10, 15]"
                    width="280"
                >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="20" />
                </Label>
                
                <!-- Description with 2 Lines -->
                <Label
                    id="descriptionLabel"
                    color="0xB0B0B0"
                    text=""
                    horizAlign="left"
                    vertAlign="top"
                    font="font:UrbanistMedium"
                    numLines="3"
                    wrap="true"
                    translation="[10, 45]"
                    width="270"
                    height="90"
                    lineSpacing="2"
                >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
                </Label>
            </Group>
            
            <!-- Floating Action Button - Centered on Image -->
            <Group id="actionButton" translation="[108, 168]" opacity="0.0">
                <Poster
                    id="playIcon"
                    uri="pkg:/images/png/episode_play.png"
                    width="84"
                    height="84"
                    loadDisplayMode="scaleToFit"
                    translation="[0, 0]"
                />
            </Group>
            
            <!-- Corner Badge for Content Type -->
            <Group id="cornerBadge" translation="[10, 10]">
                <Rectangle
                    id="badgeBackground"
                    width="100"
                    height="40"
                    color="0xFF6B6B"
                    opacity="0.9"
                />
                <Label
                    id="badgeText"
                    text="HD"
                    color="0xFFFFFF"
                    font="font:UrbanistBold"
                    horizAlign="center"
                    vertAlign="center"
                    width="100"
                    height="40"
                    translation="[0, 0]"
                >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="18" />
                </Label>
            </Group>
        </Group>
        
        <!-- Animations -->
        <Animation
            id="focusInAnimation"
            duration="0.3"
            repeat="false"
            easeFunction="outCubic"
        >
            <FloatFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[0.0, 1.0]"
                fieldToInterp="actionButton.opacity"
            />
        </Animation>
        
        <Animation
            id="focusOutAnimation"
            duration="0.2"
            repeat="false"
            easeFunction="inCubic"
        >
            <FloatFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[1.0, 0.0]"
                fieldToInterp="actionButton.opacity"
            />
        </Animation>
    </children>
</component>
