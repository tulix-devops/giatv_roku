<?xml version="1.0" encoding="utf-8" ?>
<component name="navigation_bar" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/navigation_bar.brs" />
  <interface>
    <field id="navHasFocus" type="bool" onChange="focusUpdated"/>
  </interface>
  <children>
    <Poster
      id="navBarBackground"
      uri="pkg:/images/png/gradient.jpeg"
      width="140"
      height="1080"
      loadDisplayMode="scaleToFill" />

    <!-- Search   -->
    <Group id="searchGroup" translation="[15, 60]" focusable="true" >
      <Poster
        id=""
        uri="pkg:/images/png/navigation_icons/search_icon.png"
        loadDisplayMode="scaleToZoom"
        width="48"
        height="48"
        translation="[31, 0]" />
      <Label text="Search"  color="#ffffff" font="font:UrbanistMedium" translation="[5, 47]" width="100" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
    <!-- Home -->
    <!-- 36 width Required for home Active Icon -->
    <Group id="homeGroup" translation="[15, 170]" focusable="true" >
      <Poster
        id="pockoLogo"
        uri="pkg:/images/png/navigation_icons/home_icon.png"
        width="48"
        height="48"
        loadDisplayMode="scaleToZoom"
        translation="[31, 0]" />
      <Label text="Home"  color="#ffffff" font="font:UrbanistMedium" translation="[5, 47]" width="100" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
    <!-- Live -->
    <Group id="liveGroup" translation="[15, 280]" focusable="true" >
      <Poster
        id="pockoLogo"
        uri="pkg:/images/png/navigation_icons/live_icon.png"
        width="48"
        height="48"
        loadDisplayMode="scaleToZoom"
        translation="[31, 0]" />
      <Label text="Live"  color="#ffffff" font="font:UrbanistMedium" translation="[2, 47]" width="100" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
    <!-- Video -->
    <Group id="videoGroup" translation="[15, 390]" focusable="true" >
      <Poster
        id="pockoLogo"
        uri="pkg:/images/png/navigation_icons/movie_icon.png"
        width="48"
        height="48"
        loadDisplayMode="scaleToZoom"
        translation="[31, 0]" />
      <Label text="Movies"  color="#ffffff" font="font:UrbanistMedium" translation="[5, 47]" width="100" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
    <!-- Saved -->
    <Group id="tvShowGroup" translation="[15, 500]" focusable="true">
      <Poster
        id=""
        uri="pkg:/images/png/navigation_icons/archives_icon.png"
        width="48"
        height="48"
        loadDisplayMode="scaleToZoom"
        translation="[31, 0]" />
      <Label text="TV Shows"  color="#ffffff" font="font:UrbanistMedium" translation="[0, 47]" width="110" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
    <Group id="accountGroup" translation="[15, 900]" focusable="true" width="100" height="55">
      <Poster
        id=""
        uri="pkg:/images/png/navigation_icons/account_icon.png"
        width="48"
        height="48"
        translation="[31, 0]" />
      <Label text="Account"  color="#ffffff" font="font:UrbanistMedium" translation="[5, 47]" width="100" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group>
    <!-- <Group id="exitAppGroup" translation="[15, 900]" focusable="true">
      <Poster
        id=""
        uri="pkg:/images/png/logout.png"
        width="48"
        height="48"
        loadDisplayMode="scaleToZoom"
        translation="[31, 0]" />
      <Label text="Exit"  color="#ffffff" font="font:UrbanistMedium" translation="[0, 47]" width="110" horizAlign="center">
        <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="22" />
      </Label>
    </Group> -->
    <!-- Account -->
    <!-- width 36 required for Active Icon -->
  </children>
</component>