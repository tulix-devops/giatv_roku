<?xml version="1.0" encoding="UTF-8" ?>
<component name="DetailxScene" extends="Scene">
    <script type="text/brightscript" uri="pkg:/components/DetailScene.brs"/>
    <script type="text/brightscript" uri="pkg:/components/helpers/VodEntityHelper.brs" />
    <interface>
        <field id="detailScreenData" type="array" />
        <field id="dTitle" type="string" />
        <field id="dDescr" type="string" />
        <field id="dPosterUri" type="string" />
        <field id="dTrailerUri" type="string" />
        <field id="dVideoUri" type="string" />
        <field id="relatedDataEntity" type="array" />
        <field id="parentNavigator" type="string" />
    </interface>
    <children>
        <!-- <default_poster id="default_poster" translation="[0, 0]" visible="true" /> -->
        <Animation
            id="activateDetailsPage"
            duration="0.5"
            repeat="false"
            easeFunction="linear"
        >
            <Vector2DFieldInterpolator
        id="translationInterpolator"
        key="[0.0, 1.0]"
        keyValue="[ [1920, 0], [0, 0]  ]"
        fieldToInterp="selectedVod.translation"
    />
        </Animation>
        <Animation
            id="deactivateDetailsPage"
            duration="0.5"
            repeat="false"
            easeFunction="linear"
        >
            <Vector2DFieldInterpolator
        id="translationInterpolator"
        key="[0.0, 1.0]"
        keyValue="[[0, 0], [1920, 0]   ]"
        fieldToInterp="selectedVod.translation"
    />
        </Animation>
        <Group id="selectedVod" translation="[0, 0]" visible="true" scale="1">
            <Poster
            id="posterThumb"
            uri=""
            width="1020"
            height="700"
            translation="[900, 0]"
            loadDisplayMode="scaleToZoom"
            />
            <Poster
            uri="pkg:/images/png/shapes/definetely_not_box_shadow.png"
            width="1020"
            height="250"
            translation="[900, 500]"/>
            <Poster
            uri="pkg:/images/png/shapes/left_side_box_shadow.png"
            width="250"
            height="700"
            translation="[890, 0]"/>
            <!-- uri="pkg:/images/png/shapes/left_side_box_shadow.png" -->
            <ItemDetails id="itemDetailSceneLayout" translation="[50, 0]" visible="true">
            </ItemDetails>
            <Group id="playButtonGroup" translation="[50, 500]" >
                <!-- Play Button -->
                <Poster
                id="playButtonIcon"
                uri="pkg:/images/png/play_button_empty.png"
                width="42"
                height="42"
                translation="[0, 0]" 
                loadDisplayMode="scaleToZoom"
                />
                <Label text="Play" id="playButtonText" color="0xFFFFFF" font="font:UrbanistSemiBold" translation="[60, 8]" >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="25" />
                </Label>
            </Group>
            <Group id="trailerGroup" translation="[50, 570]" focusable="true">
                <!-- Play Button -->
                <!-- Watch Trailer Button -->
                <Poster
                id="watchTrailerButtonIcon"
                uri="pkg:/images/png/play_button_empty.png"
                width="42"
                height="42"
                translation="[0, 0]" 
                loadDisplayMode="scaleToZoom"
                />
                <Label text="Watch Trailer"  id="trailerButtonText" color="0xFFFFFF" font="font:UrbanistSemiBold" translation="[60, 8]" >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="25" />
                </Label>
            </Group>
            <Group id="moreLikeThisGroup" translation="[50, 640]" >
                <!-- Play Button -->
                <!-- Watch Trailer Button -->
                <Poster
                id="moreLikeThisButtonIcon"
                uri="pkg:/images/png/more_like_this_empty.png"
                width="42"
                height="42"
                translation="[0, 0]"
                loadDisplayMode="scaleToZoom"
                />
                <Label text="More like this"  id="moreLikeThisButtonText" color="0xFFFFFF" font="font:UrbanistSemiBold" translation="[60, 8]" >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="25" />
                </Label>
                
                    <BusySpinner
                    translation="[910, 180]"
                    id="spinner"
                    uri="pkg:/images/png/loader.png"
                    visible="false"
                    control="start"
                    clockwise="true"
                    spinInterval="2"
                />
            
            </Group>
            <Group id="relatedContainer" translation="[50, 660]">
                <RowList 
                      id = "relatedList" 
                      translation = "[ 0, 0 ]" 
                      itemComponentName = "RowListItemComponent" 
                      itemSize = "[ 1920, 420 ]" 
                      rowItemSize = "[ [250, 350] ]"  
                      itemSpacing = "[ 0, 0 ]" 
                      rowItemSpacing = "[ [15,20] ]"
                      rowLabelOffset="[[0, 15]]"
                      showRowLabel = "[ true ]"
                      drawFocusFeedback = "true"
                      rowHasFocus = "false"
                      numRows="2"
                      rowFocusAnimationStyle="fixedFocus"
                      focusBitmapUri="pkg:/images/png/shapes/focusable_white.9.png"
                      />
            </Group>
        </Group>
        
        <!-- <Poster
                  id="playButton"
                  uri="pkg:/images/png/shapes/circle_empty_button.png"
                  width="189"
                  height="75"
                  translation="[452, 0]"/> -->
        <!-- <Poster
        id="saveButtonPlus"
        uri="pkg:/images/png/plus_vector.png"
        width="20"
        height="19"
        translation="[500, 27]" />
      <Label text="Save"  color="#FF4960" font="font:UrbanistSemiBold" translation="[530, 22]" >
          <Font role="font" uri="pkg:/images/UrbanistSemiBold.ttf" size="25" />
      </Label> -->
    </children>
</component>