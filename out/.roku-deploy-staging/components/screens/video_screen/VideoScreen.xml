<?xml version="1.0" encoding="UTF-8"?>
<component
    name="VideoScreen"
    extends="Group"
>

    <interface>
    	<!-- @Private -->
        <field id="contentProgram" type="node"  onChange="onProgramContentChanged" />
        <field id="navigatedFrom" type="string" />
        <!-- <field id="channelTitle" type="string"  alwaysNotify="true"/> -->
        <!-- <field id="contentProgram" type="string" onChange="onProgramContentChanged" /> -->

    </interface>

    <!-- <script type="text/brightscript" uri="pkg:/components/config/utils.brs"/> -->
    <script type="text/brightscript" uri="VideoScreen.brs" />

    <children>
        <Video
            id="videoDVRPlayer"
            width="1920"
            height="1080"
            translation="[0,0]"
            />
        <LayoutGroup 
            id="containerPlayBar"
            translation= "[0.0, 722.0]"
            layoutDirection="vert"
            vertAlign = "top"
            itemSpacings="[1]">
            <Rectangle
                    color="0x00000099"
                    id="playbarBg"
                    translation= "[0.0, 0.0]"
                    height="300"
                    width="1920"
                    >
                <LayoutGroup 
                    id="containerPlayBarStats"
                    layoutDirection="vert"
                    vertAlign = "top"
                    translation= "[12.0, 12.0]"
                    itemSpacings="[12.0]">
                    <LayoutGroup 
                        id="playBarStats"
                        layoutDirection="horiz"
                        vertAlign = "top"
                        translation= "[0.0, 0.0]"
                        itemSpacings="[21.0]">
                        <Rectangle
                            color="0x00000000"
                            id="progBarEmptySpacer"
                            translation= "[0.0, 0.0]"
                            height="10"
                            width="8"
                            />
                        <Rectangle
                            id="styledPosterArea"
                            height="129.0"
                            width="148.0"
                            color="0xFFFFFF00">
                            <Poster
                                    id="programPoster"
                                    translation= "[0.0, 12.0]"
                                    uri=""
                                    width="156.0"
                                    height="112.0"
                                    loadWidth="156.0"
                                    loadheight="112.0"
                                    loadDisplayMode="scaleToZoom"
                                    />
                        </Rectangle>
                        <LayoutGroup 
                            id="mediaDetailsBox" 
                            layoutDirection="vert"
                            itemSpacings="[12]"
                            >
                            <Label 
                                id="labelProgramTitle" 
                                color="0xFFFFFFFF"
                                font="font:LargeBoldSystemFont" 
                                width="840.0"
                                vertAlign="center"
                                text="CHANNEL PROGRAM TITLE HERE"
                                wrap="false" 
                                maxLines="1"
                            />
                            <Label 
                                id="labelProgramDescription" 
                                color="0xdededeFF"
                                font="font:MediumSystemFont" 
                                vertAlign="center"
                                text="CHANNEL TITLE | Programs Stats HERE"
                                width="840.0"
                                height="60.0"
                                maxLines="2" 
                                wrap="true"
                            />
                            <Label 
                                id="labelChannelProgInfo" 
                                color="0xdededeFF"
                                font="font:SmallSystemFont" 
                                vertAlign="center"
                                text="CHANNEL TITLE | Programs Stats HERE"
                                width="840.0"
                                maxLines="1" 
                                wrap="true"
                            />
                        </LayoutGroup>
                    </LayoutGroup>
                    <LayoutGroup 
                        id="containerProgressBar"
                        layoutDirection="horiz"
                        vertAlign = "top"
                        itemSpacings="[12.0]">
                        <Rectangle
                            color="0x00000000"
                            id="progBarEmptySpacer"
                            translation= "[0.0, 0.0]"
                            height="10"
                            width="39"
                            />
                        <Label 
                                id="labelCurrPlayTime" 
                                color="0xdededeFF"
                                font="font:SmallBoldSystemFont" 
                                width="140"
                                text="00:00:00"
                                maxLines="1" 
                                wrap="false"
                            />
                        <Rectangle
                            color="0x00000000"
                            id="progBarEmptySpacer"
                            translation= "[0.0, 0.0]"
                            height="10"
                            width="12"
                            />
                        <SeekableProgressBar
                            id="playerTimeBar"
                            visible="true"
                            barWidth="1500"
                            emptyBarBlendColor="0xc0c0c030"
                            filledBarBlendColor="0x9dd2bbFF"
                            seekBarBlendColor="0xff000090"
                            />
                        <Rectangle
                            color="0x00000000"
                            id="progBarEmptySpacer"
                            translation= "[0.0, 0.0]"
                            height="10"
                            width="1"
                            />
                        <Label 
                                id="labelTotalDuration" 
                                color="0xdededeFF"
                                width="140"
                                text="LIVE"
                                horizAlign="center"
                                vertAlign="center"
                                font="font:SmallBoldSystemFont" 
                                maxLines="1" 
                                wrap="false"
                            />
                    </LayoutGroup>
                    <LayoutGroup
                            id="programVidStats"
                            layoutDirection="horiz"
                            vertAlignment="center"
                            horizAlignment="center"
                            itemSpacings = "[21]">
                            <Rectangle
                            id="spacer"
                            height="54.0"
                            width="880.0"
                            color="0xFFFFFF00"/>
                            <Poster
                                id="iconRewind"
                                uri=""
                                width="54.0"
                                height="51.0"
                                />
                            <Poster
                                id="iconPlayPause"
                                uri="pkg:/images/pause-icon.png"
                                width="54.0"
                                height="51.0"
                                />
                            <Poster
                                id="iconForward"
                                uri=""
                                width="54.0"
                                height="51.0"
                                />
                            <Rectangle
                            id="spacer"
                            height="39.0"
                            width="372.0"
                            color="0xFFFFFF00"/>
                            <Poster
                                id="isHdIcon"
                                uri="pkg:/images/icon_hd.png"
                                width="48.0"
                                height="30.0"
                                />
                            <Poster
                                id="isCCIcon"
                                uri="pkg:/images/icon_cc.png"
                                width="48.0"
                                height="30.0"
                                />
                        </LayoutGroup>
                </LayoutGroup>

            </Rectangle>
        </LayoutGroup>
        <LayoutGroup
            id="spinnerGroup"
            translation="[640,360]"
            horizAlignment="center"
            vertAlignment="center"
            visible="true"
            >
            <BusySpinner
                id="spinner"
                uri=""
                visible="true"
            />
        </LayoutGroup>
        <Timer
                id="timerCurrentTime"
                repeat="true"
                duration="1"
            />
    </children>
</component>
