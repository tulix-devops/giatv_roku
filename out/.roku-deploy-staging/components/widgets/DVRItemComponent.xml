<?xml version="1.0" encoding="UTF-8"?>
<component name="DVRItemComponent" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentSet" />
        <field id="dvrUrl" type="string" value="" />
    </interface>
    <script type="text/brightscript" uri="DVRItemComponent.brs" />
    <children>
        <Group>
            <!-- Modern Card Container with Focus Border - Compact Size (4 per row) -->
            <Rectangle
                id="cardBackground"
                width="400"
                height="300"
                color="0x1a1f2e"
                translation="[0, 0]"
            />
            
            
            <!-- Main Poster with TRUE 16:9 Aspect Ratio (396/223 = 1.776) -->
            <Poster
              id="poster"
              uri=""
              width="396"
              height="223"
              translation="[2, 2]"
              loadDisplayMode="scaleToZoom"
            />
            
            <!-- Content Info Overlay - Adjusted for 16:9 poster -->
            <Group id="contentOverlay" translation="[2, 225]">
                <!-- Modern Dark Background -->
                <Rectangle
                    id="overlayBackground"
                    width="396"
                    height="73"
                    color="0x0f1419"
                    translation="[0, 0]"
                />
                
                <!-- Channel/Show Title - Better spacing with 73px overlay -->
                <Label
                    id="channelTitle"
                    text=""
                    color="0xFFFFFF"
                    horizAlign="left"
                    vertAlign="center"
                    font="font:UrbanistBold"
                    translation="[12, 10]"
                    width="310"
                    height="26"
                    numLines="1"
                    ellipsizeTextOnBoundary="true"
                >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="20" />
                </Label>
                
                <!-- Time Slot / Channel Info -->
                <Label
                    id="timeSlot"
                    text=""
                    color="0xE5E5E5"
                    horizAlign="left"
                    vertAlign="center"
                    font="font:UrbanistMedium"
                    translation="[12, 42]"
                    width="290"
                    height="22"
                    numLines="1"
                >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="14" />
                </Label>
                
                <!-- Duration - Hidden for live content, only visible when has value -->
                <Label
                    id="duration"
                    text=""
                    color="0xE5E5E5"
                    horizAlign="right"
                    vertAlign="center"
                    font="font:UrbanistMedium"
                    translation="[280, 42]"
                    width="100"
                    height="22"
                    numLines="1"
                    visible="false"
                >
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="14" />
                </Label>
                
                <!-- Status Indicators Container - aligned with title -->
                <Group id="statusContainer" translation="[332, 8]">
                    <!-- Live Indicator - Using image at actual size 50x30 -->
                    <Poster
                        id="liveIndicator"
                        uri="pkg:/images/png/live_50x30_small_text.png"
                        width="50"
                        height="30"
                        translation="[0, 0]"
                        visible="false"
                        loadDisplayMode="noScale"
                    />
                    
                    <!-- Recording/DVR Indicator - Below Live -->
                    <Rectangle
                        id="recordingIndicator"
                        width="55"
                        height="22"
                        color="0xFF6B6B"
                        translation="[0, 26]"
                        visible="false"
                    />
                    <Label
                        id="recordingLabel"
                        text="REC"
                        color="0xFFFFFF"
                        horizAlign="center"
                        vertAlign="center"
                        font="font:UrbanistBold"
                        translation="[0, 26]"
                        width="55"
                        height="22"
                        visible="false"
                    >
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="12" />
                    </Label>
                    
                    <!-- Premium Channel Indicator - Hidden by default -->
                    <Rectangle
                        id="premiumIndicator"
                        width="55"
                        height="22"
                        color="0xFFD700"
                        translation="[0, 26]"
                        visible="false"
                    />
                    <Label
                        id="premiumLabel"
                        text="HD"
                        color="0x000000"
                        horizAlign="center"
                        vertAlign="center"
                        font="font:UrbanistBold"
                        translation="[0, 26]"
                        width="55"
                        height="22"
                        visible="false"
                    >
                        <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="12" />
                    </Label>
                </Group>
            </Group>
            
            <!-- Modern Play Button Overlay - Centered on 16:9 poster -->
            <Group id="playButtonGroup" translation="[175, 89]" visible="false">
                <Rectangle
                    id="playButtonBg"
                    width="50"
                    height="50"
                    color="0x6366f1"
                    translation="[0, 0]"
                />
                <Poster
                    id="playButton"
                    uri="pkg:/images/png/play-icon.png"
                    width="28"
                    height="28"
                    translation="[11, 11]"
                    loadDisplayMode="scaleToFit"
                />
            </Group>
            
            <!-- Loading State - Centered on 16:9 poster -->
            <Group id="loadingGroup" translation="[183, 97]" visible="false">
                <Rectangle
                    id="loadingBg"
                    width="34"
                    height="34"
                    color="0x6366f1"
                    opacity="0.8"
                    translation="[0, 0]"
                />
                <Label
                    id="loadingText"
                    text="..."
                    color="0xFFFFFF"
                    horizAlign="center"
                    vertAlign="center"
                    translation="[0, 0]"
                    width="34"
                    height="34"
                >
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="16" />
                </Label>
            </Group>
        </Group>
    </children>
</component>