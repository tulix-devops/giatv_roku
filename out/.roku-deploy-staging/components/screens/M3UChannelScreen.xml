<?xml version="1.0" encoding="utf-8" ?>
<component name="M3UChannelScreen" extends="Group" focusable="true">
    <interface>
        <field id="m3uUrl" type="string" onChange="onM3uUrlChanged"/>
        <field id="videoPlayRequested" type="assocarray" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/M3UChannelScreen.brs"/>

    <children>
        <!-- ============================================ -->
        <!-- BACKGROUND -->
        <!-- ============================================ -->
        <Rectangle
            id="backgroundRect"
            width="1920"
            height="1080"
            color="#0a0e14"
            translation="[0, 0]"/>

        <!-- ============================================ -->
        <!-- SECTION 1: HEADER BAR (130px) -->
        <!-- ============================================ -->
        <Rectangle
            id="headerBarBg"
            translation="[0, 0]"
            width="1920"
            height="130"
            color="#0f1419"/>

        <!-- Zone 1: Screen Title (Left) -->
        <Label
            id="screenTabName"
            text="M3U Channels"
            translation="[40, 50]"
            color="#ffffff"
            width="300"
            height="44"
            vertAlign="center">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="36"/>
        </Label>

        <!-- Zone 2: Loading Status Card (Left-Center) -->
        <Rectangle
            id="loadingStatusCardBg"
            translation="[360, 18]"
            width="280"
            height="94"
            color="#1a1f2e"/>

        <Label
            id="loadingStatusTitle"
            text="Loading Status"
            translation="[360, 28]"
            color="#ffffff"
            width="280"
            horizAlign="center"
            height="32">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="24"/>
        </Label>

        <Label
            id="channelCountLabel"
            text="Loading..."
            translation="[360, 64]"
            color="#9ca3af"
            width="280"
            horizAlign="center"
            height="26">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20"/>
        </Label>

        <!-- Zone 3: Stats Card (Center) -->
        <Rectangle
            id="statsCardBg"
            translation="[660, 18]"
            width="280"
            height="94"
            color="#1a1f2e"/>

        <Label
            id="statsChannelCount"
            text="0 Channels"
            translation="[660, 28]"
            color="#ffffff"
            width="280"
            horizAlign="center"
            height="32">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="24"/>
        </Label>

        <Label
            id="selectedIndexLabel"
            text="Select a channel"
            translation="[660, 64]"
            color="#9ca3af"
            width="280"
            horizAlign="center"
            height="26">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20"/>
        </Label>

        <!-- Zone 4: Clock Card -->
        <Rectangle
            id="clockCardBg"
            translation="[960, 18]"
            width="160"
            height="94"
            color="#1a1f2e"/>

        <Label
            id="screenTimeLabel"
            text="00:00"
            translation="[960, 28]"
            color="#ffffff"
            width="160"
            horizAlign="center"
            height="36">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="28"/>
        </Label>

        <Label
            id="localTimeHint"
            text="Local Time"
            translation="[960, 68]"
            color="#9ca3af"
            width="160"
            horizAlign="center"
            height="22">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="16"/>
        </Label>

        <!-- Zone 5: Source URL Card -->
        <Rectangle
            id="sourceUrlCardBg"
            translation="[1140, 18]"
            width="540"
            height="94"
            color="#1a1f2e"/>

        <Label
            id="sourceUrlTitle"
            text="Source URL"
            translation="[1140, 28]"
            color="#ffffff"
            width="540"
            horizAlign="center"
            height="28">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="20"/>
        </Label>

        <Label
            id="sourceUrlLabel"
            text="..."
            translation="[1150, 60]"
            color="#9ca3af"
            width="520"
            horizAlign="center"
            height="44"
            maxLines="2"
            ellipsisText="...">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="16"/>
        </Label>

        <!-- Zone 6: GiaTV Logo (Far Right) -->
        <Poster
            id="screenBrandIcon"
            uri="pkg:/images/img/gia-tv-small.png"
            translation="[1700, 15]"
            width="100"
            height="100"
            loadDisplayMode="scaleToFit"/>

        <!-- Header Divider -->
        <Rectangle
            id="headerDivider"
            translation="[0, 130]"
            width="1920"
            height="2"
            color="#1e2a3a"/>

        <!-- ============================================ -->
        <!-- SECTION 2: SEARCH / OPTIONS HINT BAR -->
        <!-- ============================================ -->
        <Group id="optionsHintGroup" translation="[40, 142]">
            <Rectangle
                id="optionsAccentBar"
                translation="[0, 2]"
                width="4"
                height="28"
                color="#00bcd4"/>
            <Label
                id="searchPromptLabel"
                text="Press OPTIONS to Search"
                translation="[14, 0]"
                color="#9ca3af"
                width="500"
                height="32"
                visible="true">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="24"/>
            </Label>
        </Group>

        <!-- Search Status Group (shown during search mode) -->
        <Group id="searchStatusBar" translation="[40, 138]" visible="false">
            <Rectangle width="4" height="32" color="#00bcd4" translation="[0, 2]"/>
            <Label
                id="searchStatusLabel"
                text="Search:"
                translation="[14, 0]"
                color="#ffffff"
                width="110"
                height="36">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="26"/>
            </Label>
            <Label
                id="searchQueryText"
                text=""
                translation="[130, 0]"
                color="#00bcd4"
                width="600"
                height="36">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="26"/>
            </Label>
            <Label
                id="searchClearHint"
                text="OPTIONS: new search  •  BACK: clear"
                translation="[14, 38]"
                color="#4b5563"
                width="700"
                height="26">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20"/>
            </Label>
        </Group>

        <!-- ============================================ -->
        <!-- SECTION 3a: CATEGORY SIDEBAR -->
        <!-- ============================================ -->
        <Group id="categoryListContainer" translation="[40, 200]" visible="true">
            <Rectangle
                id="sidebarBg"
                width="295"
                height="830"
                color="#111827"/>

            <Rectangle
                id="sidebarAccentBar"
                translation="[0, 8]"
                width="4"
                height="24"
                color="#00bcd4"/>

            <Label
                id="sidebarHeaderLabel"
                text="Categories"
                translation="[14, 6]"
                color="#ffffff"
                width="200"
                height="30">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="27"/>
            </Label>

            <LabelList
                id="categoryLabelList"
                translation="[20, 42]"
                itemSize="[250, 45]"
                numRows="13"
                focusRow="0"
                drawFocusFeedback="true"
                color="#ffffff"
                focusedColor="#131720"
                vertFocusAnimationStyle="fixedFocus"
                itemSpacing="[0, 14]"
                wrap="false"
                visible="true"/>

            <Label
                id="sidebarNavHint"
                text="↑↓ Browse  •  → Channels"
                translation="[10, 800]"
                color="#4b5563"
                width="200"
                height="26">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18"/>
            </Label>
        </Group>

        <!-- ============================================ -->
        <!-- SECTION 3b: CHANNEL GRID CONTAINER -->
        <!-- ============================================ -->
        <Group id="channelGridContainer" translation="[360, 200]">

            <!-- Main Channel Grid -->
            <MarkupGrid
                id="channelGrid"
                translation="[0, 0]"
                visible="false"
                itemComponentName="M3UChannelItem"
                vertFocusAnimationStyle="floatingFocus"
                itemSize="[370, 268]"
                numColumns="4"
                numRows="3"
                itemSpacing="[18, 18]"
                drawFocusFeedback="true"
                drawFocusFeedbackOnTop="false"
                />

            <!-- Search Results Grid -->
            <MarkupGrid
                id="searchResultsGrid"
                translation="[0, 0]"
                visible="false"
                itemComponentName="M3UChannelItem"
                vertFocusAnimationStyle="floatingFocus"
                itemSize="[370, 268]"
                numColumns="4"
                numRows="3"
                itemSpacing="[18, 18]"
                drawFocusFeedback="false"/>

            <!-- ============================================ -->
            <!-- PREVIEW PLAYER OVERLAY (DISABLED) -->
            <!-- ============================================ -->
            <!-- Preview player commented out for now
            <Group id="previewPlayerContainer" translation="[0, 0]" visible="false">
                ...
            </Group>
            -->
        </Group>

        <!-- ============================================ -->
        <!-- SECTION 4: LOADING STATE CARD -->
        <!-- ============================================ -->
        <Group id="loadingGroup" translation="[660, 430]" visible="true">
            <Rectangle
                id="loadingCardBg"
                width="600"
                height="120"
                color="#1a1f2e"/>
            <Label
                id="loadingLabel"
                text="Loading M3U playlist..."
                translation="[0, 40]"
                color="#ffffff"
                width="600"
                height="40"
                horizAlign="center">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26"/>
            </Label>
        </Group>

        <!-- ============================================ -->
        <!-- SECTION 5: BOTTOM NAVIGATION BAR -->
        <!-- ============================================ -->
        <Rectangle
            id="bottomBarDivider"
            translation="[0, 1038]"
            width="1920"
            height="2"
            color="#1e2a3a"/>

        <Label
            id="bottomNavHints"
            text="OK: Play Full Screen  •  ← Categories  •  OPTIONS: Search"
            translation="[0, 1046]"
            color="#4b5563"
            width="1920"
            height="30"
            horizAlign="center">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20"/>
        </Label>

        <!-- ============================================ -->
        <!-- SECTION 6: ANIMATIONS -->
        <!-- ============================================ -->
        <Animation id="gridFadeOut" duration="0.15" repeat="false" easeFunction="outCubic">
            <FloatFieldInterpolator key="[1.0, 0.0]" fieldToInterp="channelGridContainer.opacity"/>
        </Animation>
        <Animation id="gridFadeIn" duration="0.2" repeat="false" easeFunction="outCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" fieldToInterp="channelGridContainer.opacity"/>
        </Animation>

        <!-- ============================================ -->
        <!-- SECTION 7: CLOCK TIMER -->
        <!-- ============================================ -->
        <Timer
            id="clockTimer"
            repeat="true"
            duration="60"/>
    </children>
</component>
