<?xml version="1.0" encoding="utf-8" ?>
<component name="ProgramCard" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged"/>
    </interface>
    
    <script type="text/brightscript" uri="ProgramCard.brs" />
    
    <children>
        <!-- Card background -->
        <Rectangle
            id="cardBg"
            width="360"
            height="240"
            color="#1F3B5C"
            opacity="0.8" />
        
        <!-- Program title -->
        <Label
            id="programTitle"
            text=""
            translation="[15, 15]"
            width="330"
            height="60"
            color="#FFFFFF"
            horizAlign="left"
            vertAlign="top"
            wrap="true"
            maxLines="2">
            <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="22" />
        </Label>
        
        <!-- Program time -->
        <Label
            id="programTime"
            text=""
            translation="[15, 85]"
            width="330"
            height="25"
            color="#B0B8C4"
            horizAlign="left"
            vertAlign="center">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
        </Label>
        
        <!-- Program description -->
        <Label
            id="programDesc"
            text=""
            translation="[15, 115]"
            width="330"
            height="110"
            color="#B0B8C4"
            horizAlign="left"
            vertAlign="top"
            wrap="true"
            maxLines="5">
            <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="18" />
        </Label>
    </children>
</component>
