<?xml version="1.0" encoding="utf-8" ?>
<component name="TVGuideScreen" extends="Group">
    <interface>
        <field id="visible" type="bool" value="false" onChange="onVisibleChanged" />
        <field id="contentTypeId" type="int" value="0" onChange="onContentTypeIdChanged" />
        <field id="explicitContentFocusRequested" type="int" value="0" onChange="onExplicitFocusRequested" />
        <field id="videoPlayRequested" type="assocarray" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/TVGuideScreen.brs" />

    <children>
        <!-- Background (matching dynamic_content_screen) -->
        <Rectangle 
            id="background" 
            width="1920" 
            height="1080" 
            color="#0f1419" />

        <!-- Screen Header with Tab Name and Branding (matching dynamic_content_screen exactly) -->
        <Group id="screenHeaderGroup" translation="[25, 15]" visible="true">
            <!-- Left side: Tab Name • Timestamp -->
            <Group id="headerLeftGroup" translation="[0, 0]">
                <!-- Tab Name -->
                <Label
                    id="screenTabName"
                    text="TV Guide"
                    color="#ffffff"
                    font="font:UrbanistBold"
                    horizAlign="left"
                    vertAlign="center"
                    translation="[0, 42]"
                    height="36">
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
                </Label>

                <!-- Dot Separator (blue color matching dynamic_content_screen) -->
                <Label
                    id="screenDotSeparator"
                    text="•"
                    color="#6366f1"
                    font="font:UrbanistBold"
                    horizAlign="center"
                    vertAlign="center"
                    translation="[145, 42]"
                    width="20"
                    height="36">
                    <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="32" />
                </Label>

                <!-- Local Time Display -->
                <Label
                    id="screenTimeLabel"
                    text="00:00"
                    color="#ffffff"
                    font="font:UrbanistMedium"
                    horizAlign="left"
                    vertAlign="center"
                    translation="[165, 44]"
                    height="32">
                    <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="26" />
                </Label>
            </Group>

            <!-- Right side: GiaTV Logo (120x120) -->
            <Poster
                id="screenBrandIcon"
                uri="pkg:/images/img/gia-tv-small.png"
                width="120"
                height="120"
                translation="[1710, 0]"
                loadDisplayMode="scaleToFit" />

            <!-- Header Divider Line (matching dynamic_content_screen color) -->
            <Rectangle
                id="headerDivider"
                width="1850"
                height="2"
                color="0x3A4A6AFF"
                translation="[0, 125]" />
        </Group>

        <!-- TOP LEFT: Current Channel Logo (Smaller) - Initially hidden, moved down for header -->
        <Group id="channelLogoGroup" translation="[40, 150]" visible="false" opacity="0.0">
            <Rectangle id="channelLogoBg" 
                       width="280" 
                       height="160" 
                       color="#1F3B5C"
                       opacity="0.5" />
            <Poster id="channelLogoImage"
                    uri=""
                    translation="[0, 0]"
                    width="280"
                    height="160"
                    loadingBitmapUri=""
                    failedBitmapUri="" />
            <Label id="channelLogoName"
                   text=""
                   translation="[0, 0]"
                   width="280"
                   height="160"
                   font="font:SmallBoldSystemFont"
                   color="#FFFFFF"
                   horizAlign="center"
                   vertAlign="center"
                   visible="false" />
        </Group>
        
        <!-- PROGRAM DETAILS: Wider container, shorter height - Initially hidden, moved down for header -->
        <Group id="programDetailsGroup" translation="[40, 340]" visible="false" opacity="0.0">
            <Rectangle id="detailsBg" 
                       width="560" 
                       height="210" 
                       color="#1F3B5C"
                       opacity="0.5" />
            
            <!-- Current Timestamp (at the top) -->
            <Label id="currentTimestamp" 
                   text="00:00 AM"
                   translation="[15, 10]"
                   width="530"
                   height="20"
                   color="#4FC3F7"
                   horizAlign="left"
                   vertAlign="center">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="24" />
            </Label>
            
            <Label id="programTitle" 
                   text=""
                   translation="[15, 38]"
                   width="530"
                   height="55"
                   color="#FFFFFF"
                   horizAlign="left"
                   vertAlign="top"
                   wrap="true"
                   maxLines="2">
                <Font role="font" uri="pkg:/images/UrbanistBold.ttf" size="25" />
            </Label>
            
            <Label id="programTime" 
                   text=""
                   translation="[15, 100]"
                   width="530"
                   height="25"
                   color="#B0B8C4"
                   horizAlign="left"
                   vertAlign="center">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
            </Label>
            
            <Label id="programDescription" 
                   text=""
                   translation="[15, 130]"
                   width="530"
                   height="70"
                   color="#B0B8C4"
                   horizAlign="left"
                   vertAlign="top"
                   wrap="true"
                   maxLines="3">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="20" />
            </Label>
        </Group>

        <!-- BACK NAVIGATION HINT: Separate container below program details -->
        <Group id="backHintGroup" translation="[40, 550]" visible="false" opacity="0.0">
            <Rectangle id="backHintBg" 
                       width="560" 
                       height="50" 
                       color="#1F3B5C"
                       opacity="0.5" />
            
            <Label id="backHint" 
                   text="Press BACK for Navigation"
                   translation="[15, 15]"
                   width="530"
                   height="20"
                   color="#4FC3F7"
                   horizAlign="left"
                   vertAlign="center">
                <Font role="font" uri="pkg:/images/UrbanistMedium.ttf" size="28" />
            </Label>
        </Group>

        <!-- VIDEO PLAYER: Right side - Narrower width - Initially hidden, moved down and reduced height for header -->
        <Group id="videoPlayerGroup" translation="[670, 150]" visible="false" opacity="0.0">
            <Rectangle id="videoPlayerBg" 
                       width="1200" 
                       height="480" 
                       color="#000000"
                       opacity="1.0" />
            <Video id="videoPlayer"
                   translation="[0, 0]"
                   width="1200"
                   height="480"
                   visible="true"
                   loop="false"
                   control="stop"
                   enableUI="false" />
            <Label id="videoPlayerStatus"
                   text=""
                   translation="[0, 0]"
                   width="1200"
                   height="480"
                   font="font:MediumSystemFont"
                   color="#FFFFFF"
                   horizAlign="center"
                   vertAlign="center"
                   visible="false" />
        </Group>

        <!-- TV GUIDE GRID (TimeGrid Component) - Moved down for header, reduced to 12 rows -->
        <TimeGrid
            id="timeGrid"
            translation="[0, 175]"
            width="1920"
            height="905"
            visible="true"
            focusable="true"
            channelInfoComponentName="EPGChannelItem"
            numRows="12"
            fillProgramGaps="true"
            showPastTimeScreen="false"
            duration="9000"
            maxDays="1"
            channelInfoWidth="160"
            programInfoBackgroundColor="#1F3B5C"
            programInfoFocusedBackgroundColor="#4FC3F7"
            timeBarHeight="40"
            timeBarTextColor="#FFFFFF"
            timeBarBackgroundColor="#1F3B5C"
            gridBackgroundColor="#0f1419"
            channelInfoBackgroundColor="#1F3B5C"
            channelNoDataText=""
            loadingDataText="TV Guide Loading..."
            nowBarBlendColor="0xFF000000"
            nowBarThickness="0"
            nowBarWidth="0"
            nowBarOffset="0"
            minimumNowBarOffset="0" />

        <!-- ANIMATIONS -->
        <!-- Animation to move TimeGrid down and shrink it (opening detail view) -->
        <Animation id="timeGridMoveDownAnimation" duration="0.4" easeFunction="outCubic">
            <Vector2DFieldInterpolator 
                id="timeGridTranslationDownInterp"
                key="[0.0, 1.0]"
                keyValue="[[0, 175], [0, 680]]"
                fieldToInterp="timeGrid.translation" />
            <Vector2DFieldInterpolator 
                id="timeGridHeightDownInterp"
                key="[0.0, 1.0]"
                keyValue="[[1920, 905], [1920, 400]]"
                fieldToInterp="timeGrid.height" />
        </Animation>

        <!-- Animation to move TimeGrid up and expand it (closing detail view) -->
        <Animation id="timeGridMoveUpAnimation" duration="0.4" easeFunction="outCubic">
            <Vector2DFieldInterpolator 
                id="timeGridTranslationUpInterp"
                key="[0.0, 1.0]"
                keyValue="[[0, 680], [0, 175]]"
                fieldToInterp="timeGrid.translation" />
            <Vector2DFieldInterpolator 
                id="timeGridHeightUpInterp"
                key="[0.0, 1.0]"
                keyValue="[[1920, 400], [1920, 905]]"
                fieldToInterp="timeGrid.height" />
        </Animation>

        <!-- Fade in animations for detail groups -->
        <Animation id="programDetailsFadeInAnimation" duration="0.3" delay="0.2" easeFunction="inOutCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="programDetailsGroup.opacity" />
        </Animation>
        <Animation id="videoPlayerFadeInAnimation" duration="0.3" delay="0.2" easeFunction="inOutCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="videoPlayerGroup.opacity" />
        </Animation>
        <Animation id="channelLogoFadeInAnimation" duration="0.3" delay="0.2" easeFunction="inOutCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="channelLogoGroup.opacity" />
        </Animation>

        <!-- Fade out animations for detail groups -->
        <Animation id="programDetailsFadeOutAnimation" duration="0.2" easeFunction="inOutCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="programDetailsGroup.opacity" />
        </Animation>
        <Animation id="videoPlayerFadeOutAnimation" duration="0.2" easeFunction="inOutCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="videoPlayerGroup.opacity" />
        </Animation>
        <Animation id="channelLogoFadeOutAnimation" duration="0.2" easeFunction="inOutCubic">
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="channelLogoGroup.opacity" />
        </Animation>
    </children>
</component>
