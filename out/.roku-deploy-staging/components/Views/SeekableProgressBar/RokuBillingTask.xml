<!--
    Node which implements interaction with Roku Billing system using roChannelStore object.
    Provides functions for usage inside SceneGraph components: GetPartialUserData, GetProducts, PurchaseProduct.
    Parameters and results of the functions are passed via field interfaces.
    
    Sample:
    
    m.billing = m.top.CreateChild("RokuBillingTask")
    
    ' customize user data to share
    m.billing.userDataToShare = "email,zip"
    
    ' select function to get data
    m.billing.functionName = "GetPartialUserData"
    
    ' observe shared user data
    m.billing.ObserveField("partialUserData", "On_billing_partialUserData")
    
    ' call function
    m.billing.control = "RUN"
-->
<component name="RokuBillingTask" extends="Task">

<interface>

	<field id="rokuCancelledOrderId"     type="string"    alwaysNotify="true"/>
	<field id="bIsCancelledSubscription"     type="bool"    alwaysNotify="true"/>
	<field id="bHasValidSubscription"     type="bool"    alwaysNotify="true"/>
		
	<field id="rokuStoreSubscriptions"     type="assocarray"    alwaysNotify="true"/>
	<field id="userRokuSubscriptions"     type="assocarray"    alwaysNotify="true"/>
	
	<field id="isRokuPurchasedSubscriptionExpired"     type="bool"    alwaysNotify="true"/>
	
    <!-- WRITE-ONLY. Specifies user data to share for GetPartialUserData function in the same format as for 
         similar roChannelStore's function (comma-separated string of needed data fields e.g. "email,zip"). -->
    <field id="userDataToShare"     type="string"        alwaysNotify="true"    value="email"/>
    
    <!-- WRITE-ONLY. Specifies product index to purchase in the list of available products (see "products").
         Used as a parameter for PurchaseProduct function and calls it automatically. -->
    <field id="indexPurchase"       type="int"           alwaysNotify="true"    onChange="On_indexPurchase"/>
    
    
    <!-- OBSERVE-ONLY. Set when GetPartialUserData function is complete (see "userDataToShare"). Value format
         is the same as for roChannelStore's GetPartialUserData result -->
    <field id="partialUserData"     type="assocarray"    alwaysNotify="true"/>
    
    <field id="isNewAccount"     type="bool"    alwaysNotify="true"/>
    <field id="isAccountActive"     type="bool"    alwaysNotify="true"/>
    <field id="isAccountLinked"     type="bool"    alwaysNotify="true"/>
    
    
    <!-- OBSERVE-ONLY. Set as a result of GetProducts function call when it completes.
         Value is always an associative array:
            {
                availForPurchase : {
                    list : [],
                    map  : {}
                },
                validPurchased : {
                    list : [],
                    map  : {}
                }
            } 
         where availForPurchase relates to products available for purchase,
         validPurchased - to valid purchased products. -->
    <field id="products"            type="assocarray"    alwaysNotify="true"/>
    
    	<field id="arrayProductsName" type="array"      alwaysNotify="true"/>
    
    <!-- OBSERVE-ONLY. Set as a result of PurchaseProduct function (see "indexPurchase"). Value is always
         an associative array containing subfields:
            isSuccess (boolean flag of success);
            fields of roChannelStore's DoOrder() response (if isSuccess=True);
            failureCode (integer value if isSuccess=False);
            failureMessage (string value if isSuccess=False). -->
    <field id="purchaseResult"      type="assocarray"    alwaysNotify="true"/>
</interface> 


<script type="text/brightscript"  uri="pkg:/components/Views/SeekableProgressBar/RokuBillingTask.brs"/>

</component>
